---
import { site } from '../config/site';
import CartIcon from './CartIcon.svelte';

const navLinks = [
  { href: '/collections/bait-boards', label: 'Bait Boards' },
  { href: '/collections/on-sale', label: 'On Sale' },
  { href: '/help-me-choose', label: 'Help Me Choose' },
  { href: '/articles', label: 'Guides' },
  { href: '/contact', label: 'Contact' },
  { href: '/about', label: 'About' },
  { href: '/faqs', label: 'FAQs' },
];

const path = Astro.url.pathname;
---

<header class="bg-white border-b border-[#e6e6e6]" style="box-shadow: 0 1px 4px rgba(0,0,0,0.06);">
  <nav class="container flex items-center justify-between" style="min-height: 99px;">

    <!-- Logo -->
    <a href="/" aria-label={site.name} class="flex-shrink-0">
      <img src="/images/logo.webp" alt="Bait Boards Direct" width="180" height="47" class="h-10 w-auto object-contain" loading="eager" fetchpriority="high" />
    </a>

    <!-- Desktop nav -->
    <ul class="hidden items-center gap-7 lg:flex">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class={`font-heading text-xs font-semibold uppercase tracking-widest transition-colors hover:text-accent ${
              path.startsWith(href) ? 'text-accent' : 'text-[#07272e]'
            }`}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Cart + hamburger -->
    <div class="flex items-center gap-4">
      <div class="text-[#07272e]">
        <CartIcon client:idle />
      </div>
      <button
        id="mobile-menu-btn"
        class="text-[#07272e] hover:text-accent lg:hidden"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </nav>
</header>

<!-- Mobile drawer (outside header so it overlays whole page) -->
<div id="mobile-menu" class="fixed inset-0 z-50 hidden" inert role="dialog" aria-modal="true" aria-label="Navigation menu">
  <div id="mobile-backdrop" class="absolute inset-0 bg-black/60"></div>
  <div class="absolute right-0 top-0 h-full w-72 max-w-[85vw] bg-white shadow-2xl flex flex-col">
    <div class="flex items-center justify-between border-b border-[#e6e6e6] px-6 py-5">
      <span class="font-heading text-base font-bold text-[#07272e]">Menu</span>
      <button id="mobile-menu-close" class="text-[#07272e]/70 hover:text-[#07272e]" aria-label="Close navigation menu">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    <ul class="flex flex-col px-6 py-4">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class="block border-b border-[#e6e6e6] py-4 font-heading text-sm font-semibold uppercase tracking-widest text-[#07272e] transition-colors hover:text-accent"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</div>

<script is:inline>
  (function () {
    var btn = document.getElementById('mobile-menu-btn');
    var close = document.getElementById('mobile-menu-close');
    var menu = document.getElementById('mobile-menu');
    var backdrop = document.getElementById('mobile-backdrop');

    function open() {
      menu.classList.remove('hidden');
      menu.removeAttribute('inert');
      btn.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }
    function shut() {
      menu.classList.add('hidden');
      menu.setAttribute('inert', '');
      btn.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }

    if (btn) btn.addEventListener('click', open);
    if (close) close.addEventListener('click', shut);
    if (backdrop) backdrop.addEventListener('click', shut);
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape') shut(); });
  })();
</script>
