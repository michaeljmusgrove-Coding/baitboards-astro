---
import { site } from '../config/site';

const hasPhone = !site.contact.phone.includes('__TODO__');
const hasEmail = !site.contact.email.includes('__TODO__');

const items = [
  "Free Shipping Australia Wide",
  "Got a Question?",
  ...(hasPhone ? [`Call Us: ${site.contact.phone}`] : []),
  ...(hasEmail ? [`Email: ${site.contact.email}`] : []),
];
---

<div class="overflow-hidden bg-dark-hero border-b border-white/10" aria-label="Site announcements">
  <ul class="announcement-track m-0 flex list-none p-0">
    {items.map((item) => (
      <li class="inline-flex shrink-0 items-center gap-2.5 whitespace-nowrap px-[60px] py-3 font-heading text-sm font-normal text-white sm:text-base">
        <span class="text-accent text-sm leading-none" aria-hidden="true">&bull;</span>
        {item}
      </li>
    ))}
    {/* Duplicate for seamless loop */}
    {items.map((item) => (
      <li class="inline-flex shrink-0 items-center gap-2.5 whitespace-nowrap px-10 py-2.5 text-xs font-medium text-white/80" aria-hidden="true">
        <span class="text-accent text-sm leading-none">&bull;</span>
        {item}
      </li>
    ))}
  </ul>
</div>

<style>
  .announcement-track {
    animation: announcement-scroll 20s linear infinite;
  }
  .announcement-track:hover {
    animation-play-state: paused;
  }
  @media (prefers-reduced-motion: reduce) {
    .announcement-track {
      animation: none;
    }
  }
  @keyframes announcement-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
</style>
