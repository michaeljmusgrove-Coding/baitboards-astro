---
import { site } from '../config/site';

const quickLinks = [
  { href: '/collections/bait-boards', label: 'Bait Boards' },
  { href: '/collections/bait-boards-with-legs', label: 'Bait Boards with Legs' },
  { href: '/collections/on-sale', label: 'On Sale' },
  { href: '/about', label: 'About Us' },
  { href: '/contact', label: 'Contact' },
  { href: '/faqs', label: 'FAQs' },
];

const legalLinks = [
  { href: '/privacy-policy', label: 'Privacy Policy' },
  { href: '/returns', label: 'Returns & Refunds' },
  { href: '/shipping', label: 'Shipping Policy' },
  { href: '/terms', label: 'Terms of Service' },
  { href: '/contact', label: 'Contact Us' },
];

const paymentMethods = ['Visa', 'Mastercard', 'PayPal', 'Amex', 'Apple Pay', 'Google Pay', 'Shop Pay', 'Afterpay'];

const year = new Date().getFullYear();
const hasFacebook = !site.social.facebook.includes('__TODO__');
const hasInstagram = !site.social.instagram.includes('__TODO__');
---

<footer class="bg-[#f7f7f7] border-t border-gray-200">
  <div class="container py-14 text-[#07272e]">
    <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4">

      <!-- Brand -->
      <div>
        <a href="/" class="inline-block mb-5">
          <img src="/images/logo.png" alt="Bait Boards Direct" width="180" height="47" class="h-9 w-auto" loading="lazy" />
        </a>
        <p class="text-sm leading-relaxed text-[#07272e]/70 max-w-xs">
          At Bait Boards Direct, we're all about top-quality bait boards that make your fishing trips easier and more fun. Built tough and ready for action!
        </p>
        {(hasFacebook || hasInstagram) && (
          <div class="mt-5 flex items-center gap-4">
            {hasFacebook && (
              <a href={site.social.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook"
                class="text-[#07272e]/50 transition-colors hover:text-[#008c9e]">
                <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/>
                </svg>
              </a>
            )}
            {hasInstagram && (
              <a href={site.social.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram"
                class="text-[#07272e]/50 transition-colors hover:text-[#008c9e]">
                <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z"/>
                </svg>
              </a>
            )}
          </div>
        )}
      </div>

      <!-- Newsletter -->
      <div>
        <h3 class="font-heading mb-4 text-xs font-semibold uppercase tracking-widest text-[#07272e]">
          Subscribe to our emails
        </h3>
        <p class="mb-3 text-sm text-[#07272e]/70">
          Be the first to know about new collections and exclusive offers.
        </p>
        <form class="flex gap-2" method="POST" action="/newsletter">
          <input
            type="email"
            name="email"
            placeholder="Email"
            required
            class="flex-1 min-w-0 rounded-full border border-gray-300 bg-white px-4 py-2 text-sm text-[#07272e] outline-none focus:border-[#008c9e]"
          />
          <button
            type="submit"
            class="button-accent"
            style="padding: 8px 18px; font-size: 12px;"
          >
            Subscribe
          </button>
        </form>
      </div>

      <!-- Shop links -->
      <div>
        <h3 class="font-heading mb-4 text-xs font-semibold uppercase tracking-widest text-[#07272e]">Shop</h3>
        <ul class="space-y-2.5">
          {quickLinks.map(({ href, label }) => (
            <li>
              <a href={href} class="text-sm text-[#07272e]/80 transition-colors hover:text-[#07272e]">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Legal / more info -->
      <div>
        <h3 class="font-heading mb-4 text-xs font-semibold uppercase tracking-widest text-[#07272e]">More Info</h3>
        <ul class="space-y-2.5">
          {legalLinks.map(({ href, label }) => (
            <li>
              <a href={href} class="text-sm text-[#07272e]/80 transition-colors hover:text-[#07272e]">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Payment icons + bottom bar -->
    <div class="mt-8 border-t border-gray-300 pt-6 flex flex-wrap items-center justify-between gap-4">
      <p class="text-xs text-[#07272e]/60">
        &copy; {year} {site.name}. All rights reserved. Website and Marketing by
        <a href="https://fadigital.com.au" target="_blank" rel="noopener noreferrer" class="underline hover:text-[#008c9e]">FA Digital</a>
      </p>
      <div class="flex flex-wrap gap-2">
        {paymentMethods.map(m => (
          <span class="inline-block rounded border border-gray-300 bg-white px-2 py-1 text-[10px] font-semibold text-[#07272e]">
            {m}
          </span>
        ))}
      </div>
    </div>
  </div>
</footer>
