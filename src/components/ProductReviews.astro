---
interface Props {
  shopifyId: string;
  handle: string;
  reviewCount?: number;
}
const { shopifyId, handle, reviewCount = 0 } = Astro.props;
---

<section class="border-t border-border py-12">
  <div class="container max-w-3xl">
    <h2 class="font-heading mb-8 text-2xl font-bold text-text">Customer Reviews</h2>
    <div
      class="jdgm-widget jdgm-review-widget"
      data-id={shopifyId}
      data-handle={handle}
      data-number-of-reviews={reviewCount}>
    </div>
  </div>
</section>

<!-- Pre-initialise jdgm config before widget script loads (required for headless — no window.Shopify) -->
<script is:inline>
  window.jdgm = window.jdgm || {};
  window.jdgm.SHOP_DOMAIN = 'd26601.myshopify.com';
  window.jdgm.PLATFORM = 'shopify';
  window.jdgm.PUBLIC_TOKEN = 'KzLexidX1I2wx23jcKm9c-xKOQl';
</script>
<script
  src="https://cdn.judge.me/assets/shopify-widgets.js?shop=d26601.myshopify.com"
  async
  is:inline
></script>
