---
interface Review {
  id: number;
  title?: string;
  body?: string;
  rating: number;
  reviewer?: { name?: string; verified_buyer?: boolean };
  created_at?: string;
  pictures?: { urls?: { huge?: string } }[];
}

interface Props {
  handle: string;
  reviews: Review[];
  rating: number | null;
  reviewCount: number;
}

const { handle, reviews, rating, reviewCount } = Astro.props;

function stars(n: number) {
  const full = Math.round(n);
  return '★'.repeat(full) + '☆'.repeat(5 - full);
}

function formatDate(iso?: string) {
  if (!iso) return '';
  return new Date(iso).toLocaleDateString('en-AU', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<section class="border-t border-border py-12">
  <div class="container max-w-3xl">
    <h2 class="font-heading mb-8 text-2xl font-bold text-text">Customer Reviews</h2>

    {reviews.length > 0 ? (
      <div>
        {/* Aggregate summary */}
        {rating !== null && (
          <div class="mb-8 flex items-center gap-4 rounded-2xl border border-border bg-bg-alt p-5">
            <div class="text-center">
              <div class="text-4xl font-bold text-text">{rating.toFixed(1)}</div>
              <div class="mt-1 text-lg text-[#008c9e]">{stars(rating)}</div>
              <div class="mt-1 text-xs text-text-muted">{reviewCount} {reviewCount === 1 ? 'review' : 'reviews'}</div>
            </div>
            <div class="h-12 w-px bg-border"></div>
            <p class="text-sm text-text-muted leading-relaxed">
              Based on verified customer purchases. All reviews collected via Judge.me.
            </p>
          </div>
        )}

        {/* Review list */}
        <div class="divide-y divide-border">
          {reviews.map((review) => (
            <div class="py-6">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <div class="text-[#008c9e]" aria-label={`${review.rating} out of 5 stars`}>
                    {stars(review.rating)}
                  </div>
                  {review.title && (
                    <p class="mt-1 font-bold text-text">{review.title}</p>
                  )}
                </div>
                <div class="shrink-0 text-right text-xs text-text-muted">
                  <div>{review.reviewer?.name ?? 'Verified Buyer'}</div>
                  {review.reviewer?.verified_buyer && (
                    <div class="mt-0.5 font-bold text-[#008c9e]">✓ Verified</div>
                  )}
                  <div class="mt-0.5">{formatDate(review.created_at)}</div>
                </div>
              </div>
              {review.body && (
                <p class="mt-3 text-sm leading-relaxed text-text-muted">{review.body}</p>
              )}
              {review.pictures && review.pictures.length > 0 && (
                <div class="mt-3 flex flex-wrap gap-2">
                  {review.pictures.slice(0, 4).map((pic) => pic.urls?.huge && (
                    <img
                      src={pic.urls.huge}
                      alt="Customer review photo"
                      class="h-20 w-20 rounded-lg object-cover"
                      loading="lazy"
                      width="80"
                      height="80"
                    />
                  ))}
                </div>
              )}
            </div>
          ))}
        </div>
      </div>
    ) : (
      <div class="rounded-2xl border border-border bg-bg-alt p-8 text-center">
        <div class="mb-2 text-3xl text-text-muted">☆☆☆☆☆</div>
        <p class="font-bold text-text">No reviews yet</p>
        <p class="mt-1 text-sm text-text-muted">
          Be the first — review requests are sent automatically after purchase.
        </p>
      </div>
    )}
  </div>
</section>
