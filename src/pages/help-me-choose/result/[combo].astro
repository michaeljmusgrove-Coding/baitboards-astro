---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getAllProducts, formatPrice, type NormalizedProduct } from '../../../utils/shopify';
import { ALL_COMBOS, getRecommendation, describeAnswers, type Fishing, type Boat, type Rods } from '../../../utils/quiz';

export async function getStaticPaths() {
  const products = await getAllProducts(250);
  const productMap = new Map(products.map((p) => [p.handle, p]));

  return ALL_COMBOS.map(({ fishing, boat, rods }) => {
    const rec = getRecommendation(fishing, boat, rods);
    const product = productMap.get(rec.productHandle) ?? null;
    const alt = rec.alternativeHandle ? productMap.get(rec.alternativeHandle) ?? null : null;
    return {
      params: { combo: `${fishing}-${boat}-${rods}` },
      props: { fishing, boat, rods, recommendation: rec, product, alt },
    };
  });
}

interface Props {
  fishing: Fishing;
  boat: Boat;
  rods: Rods;
  recommendation: { productHandle: string; reason: string; alternativeHandle?: string };
  product: NormalizedProduct | null;
  alt: NormalizedProduct | null;
}

const { fishing, boat, rods, recommendation, product, alt } = Astro.props;
const summary = describeAnswers(fishing, boat, rods);

// Pick the available product (prefer primary, fall back to alternative if primary is sold out)
const display = (product?.availableForSale ? product : (alt?.availableForSale ? alt : product)) ?? null;
const isAlt = display !== null && display.handle !== recommendation.productHandle;

const title = display
  ? `Recommended: ${display.title} | Bait Boards Direct`
  : `Your Bait Board Recommendation | Bait Boards Direct`;
const description = `For ${summary}, we recommend the ${display?.title ?? 'right SeaKing model'}. ${recommendation.reason}`;
---

<BaseLayout title={title} description={description}>

  <!-- Result hero -->
  <section class="bg-dark-hero py-14 text-white">
    <div class="container max-w-3xl">
      <p class="mb-2 text-xs font-semibold uppercase tracking-widest text-accent">
        <a href="/help-me-choose" class="hover:underline">Help Me Choose</a> &rsaquo; Your match
      </p>
      <h1 class="font-heading mb-4 text-3xl font-extrabold sm:text-4xl">Your Recommended Bait Board</h1>
      <p class="text-sm leading-relaxed text-white/80 sm:text-base">
        Based on your answers — <strong class="text-white">{summary}</strong> — here's the SeaKing model Harry would put on your boat.
      </p>
    </div>
  </section>

  <!-- Recommendation card -->
  <section class="bg-white py-12 sm:py-16">
    <div class="container max-w-3xl">

      {display ? (
        <div class="rounded-2xl border border-border bg-white p-6 shadow-sm sm:p-8">
          <div class="grid gap-6 md:grid-cols-2 md:gap-8">
            <a href={`/products/${display.handle}`} class="block overflow-hidden rounded-xl bg-bg-alt">
              <img
                src={display.image}
                alt={display.title}
                class="h-full w-full object-cover transition-transform hover:scale-105"
                width="600"
                height="600"
                loading="lazy"
              />
            </a>
            <div class="flex flex-col">
              {isAlt && (
                <p class="mb-2 text-xs font-semibold uppercase tracking-widest text-warn-text">Alternative — primary pick is sold out</p>
              )}
              <h2 class="font-heading text-2xl font-extrabold leading-tight text-primary sm:text-3xl">
                <a href={`/products/${display.handle}`} class="hover:text-accent">
                  {display.title}
                </a>
              </h2>
              <div class="mt-3 flex items-center gap-3">
                <span class="text-2xl font-bold text-[#07272e]">{formatPrice(display.price)}</span>
                {display.compareAtPrice && (
                  <span class="text-base text-text-muted line-through">{formatPrice(display.compareAtPrice)}</span>
                )}
              </div>
              <p class="mt-5 text-sm leading-relaxed text-text-muted sm:text-base">
                {recommendation.reason}
              </p>
              <a href={`/products/${display.handle}`} class="mt-8 button-accent self-start">View product details</a>
            </div>
          </div>
        </div>
      ) : (
        <div class="rounded-2xl border border-border bg-white p-8 text-center">
          <h2 class="font-heading mb-3 text-2xl font-bold text-primary">Recommendation unavailable</h2>
          <p class="mb-6 text-sm leading-relaxed text-text-muted sm:text-base">
            The board we'd suggest for {summary} is currently being restocked. Browse the full SeaKing range for the closest match — or contact us and we'll point you to the right model.
          </p>
          <div class="flex flex-wrap justify-center gap-3">
            <a href="/collections/bait-boards" class="button-accent">Browse all bait boards</a>
            <a href="/contact" class="button">Contact us</a>
          </div>
        </div>
      )}

      <!-- Why this pick -->
      <div class="mt-10 rounded-2xl bg-bg-alt p-6 sm:p-8">
        <h3 class="font-heading mb-3 text-base font-bold uppercase tracking-wide text-primary">Why this pick</h3>
        <p class="text-sm leading-relaxed text-text-muted sm:text-base">
          The recommendation matrix was built by our founder Harry — a working fibreglass boat builder with over 20 years of marine composite construction experience. He has handled, mounted, and tested every SeaKing model in the range. Your match is the model he'd choose for your setup.
        </p>
        <a href="/about#founder" class="mt-4 inline-block text-sm font-semibold text-accent underline underline-offset-2 hover:text-primary">Read more about Harry &rarr;</a>
      </div>

      <!-- Retake / browse -->
      <div class="mt-12 flex flex-wrap justify-center gap-3">
        <a href="/help-me-choose" class="button">Retake the quiz</a>
        <a href="/collections/bait-boards" class="button-accent">Browse all bait boards</a>
      </div>

    </div>
  </section>

</BaseLayout>
