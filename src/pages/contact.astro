---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../config/site';

const title = "Contact Bait Boards Direct";
const description = "Get in touch with Bait Boards Direct. We're based in South East Melbourne and happy to answer questions about our fiberglass bait boards, shipping, or custom setups.";

const hasPhone = !site.contact.phone.includes('__TODO__');
const hasEmail = !site.contact.email.includes('__TODO__');
---

<BaseLayout title={title} description={description}>
  <section class="bg-bg-alt py-16 sm:py-20">
    <div class="container max-w-2xl">
      <h1 class="font-heading mb-4 text-3xl font-bold text-primary sm:text-4xl">Contact Us</h1>
      <p class="mb-10 text-text-muted">
        Questions about a product, your order, or shipping? We're based in South East Melbourne and aim to respond within one business day.
      </p>

      {(hasPhone || hasEmail) && (
        <div class="mb-10 flex flex-col gap-4 sm:flex-row sm:gap-8">
          {hasPhone && (
            <a href={`tel:${site.contact.phone}`} class="flex items-center gap-2 font-semibold text-primary hover:text-accent transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              {site.contact.phone}
            </a>
          )}
          {hasEmail && (
            <a href={`mailto:${site.contact.email}`} class="flex items-center gap-2 font-semibold text-primary hover:text-accent transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              {site.contact.email}
            </a>
          )}
        </div>
      )}

      <!-- Contact form via Web3Forms -->
      <form
        action="https://api.web3forms.com/submit"
        method="POST"
        class="space-y-5 rounded-xl border border-border bg-white p-6 sm:p-8"
      >
        <input type="hidden" name="access_key" value="__TODO__" />
        <input type="hidden" name="subject" value="New enquiry from Bait Boards Direct website" />
        <input type="checkbox" name="botcheck" class="hidden" style="display:none" />

        <div>
          <label for="name" class="mb-1.5 block text-sm font-medium text-primary">Name</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            autocomplete="name"
            class="w-full rounded-lg border border-border px-4 py-2.5 text-sm focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
          />
        </div>
        <div>
          <label for="email" class="mb-1.5 block text-sm font-medium text-primary">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            autocomplete="email"
            class="w-full rounded-lg border border-border px-4 py-2.5 text-sm focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
          />
        </div>
        <div>
          <label for="message" class="mb-1.5 block text-sm font-medium text-primary">Message</label>
          <textarea
            id="message"
            name="message"
            rows="5"
            required
            class="w-full rounded-lg border border-border px-4 py-2.5 text-sm focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
          ></textarea>
        </div>
        <button type="submit" class="button w-full sm:w-auto">
          Send Message
        </button>
      </form>
    </div>
  </section>
</BaseLayout>
