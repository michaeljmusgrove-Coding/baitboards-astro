---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../config/site';

const title = "Contact Bait Boards Direct — Bait Board Sizing & Bulk Quotes Australia";
const description = "Contact Bait Boards Direct for fibreglass bait board sizing advice, mounting compatibility, and bulk quotes for charter operations and fishing clubs. Based in South East Melbourne, ships Australia-wide.";

const hasPhone = !site.contact.phone.includes('__TODO__');
const hasEmail = !site.contact.email.includes('__TODO__');

const schema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  '@id': `${site.domain}/contact`,
  name: 'Contact Bait Boards Direct',
  url: `${site.domain}/contact`,
  description,
  about: { '@type': 'SportingGoodsStore', '@id': `${site.domain}/#store` },
};
---

<BaseLayout title={title} description={description} schema={schema}>
  <section class="bg-bg-alt py-16 sm:py-20">
    <div class="container max-w-2xl">
      <h1 class="font-heading mb-4 text-3xl font-bold text-primary sm:text-4xl">Contact Us</h1>
      <p class="mb-10 text-text-muted">
        Questions about a product, your order, or shipping? We're based in South East Melbourne and aim to respond within one business day.
      </p>

      {(hasPhone || hasEmail) && (
        <div class="mb-10 flex flex-col gap-4 sm:flex-row sm:gap-8">
          {hasPhone && (
            <a href={`tel:${site.contact.phone}`} class="flex items-center gap-2 font-bold text-primary hover:text-accent-text transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              {site.contact.phone}
            </a>
          )}
          {hasEmail && (
            <a href={`mailto:${site.contact.email}`} class="flex items-center gap-2 font-bold text-primary hover:text-accent-text transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              {site.contact.email}
            </a>
          )}
        </div>
      )}

      <!-- Email CTA (form deferred to Day 2 — Web3Forms integration pending) -->
      {hasEmail && (
        <div class="rounded-xl border border-border bg-white p-6 sm:p-8">
          <h2 class="font-heading mb-3 text-xl font-bold text-primary">Send us an enquiry</h2>
          <p class="mb-6 text-text-muted">
            Email us with your boat model, transom width, and how you plan to use the bait board.
            We aim to respond within one business day.
          </p>
          <a
            href={`mailto:${site.contact.email}?subject=Bait%20Boards%20Direct%20enquiry`}
            class="button-accent inline-flex items-center gap-2"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            Email {site.contact.email}
          </a>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
