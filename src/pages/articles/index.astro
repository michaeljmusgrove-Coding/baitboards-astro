---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { site } from '../../config/site';

const articles = (await getCollection('articles', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());

const title = "Bait Board Articles & Buying Guides | Bait Boards Direct";
const description = "Practical guides for Australian anglers — choosing the right bait board, installing it properly, comparing materials, and getting the most from your setup. Written by working marine professionals.";

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': `${site.domain}/articles`,
  name: 'Bait Board Articles & Buying Guides',
  url: `${site.domain}/articles`,
  description,
  isPartOf: { '@id': `${site.domain}/#website` },
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: articles.map((a, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: `${site.domain}/articles/${a.id}`,
      name: a.data.title,
    })),
  },
};
---

<BaseLayout title={title} description={description} schema={schema}>

  <!-- Header -->
  <section class="bg-dark-hero py-14 text-white">
    <div class="container max-w-3xl">
      <p class="mb-2 text-xs font-semibold uppercase tracking-widest text-accent-on-dark">
        <a href="/" class="hover:underline">Home</a> &rsaquo; Articles
      </p>
      <h1 class="font-heading text-3xl font-extrabold sm:text-4xl">Bait Board Articles &amp; Buying Guides</h1>
      <p class="mt-3 max-w-2xl text-sm leading-relaxed text-white/70 sm:text-base">
        Practical, plain-English guides for picking, installing, and maintaining a bait board on your boat. Written by working marine professionals — not marketing copy.
      </p>
    </div>
  </section>

  <!-- Article list -->
  <section class="bg-white py-12 sm:py-16">
    <div class="container max-w-3xl">
      <div class="grid gap-6">
        {articles.map((article) => (
          <a
            href={`/articles/${article.id}`}
            class="group block rounded-2xl border border-border bg-white p-6 shadow-sm transition hover:border-accent hover:shadow-md sm:p-8"
          >
            <div class="flex flex-col gap-3">
              <p class="text-xs font-semibold uppercase tracking-widest text-accent-on-dark">
                {article.data.publishedAt.toLocaleDateString('en-AU', { year: 'numeric', month: 'long', day: 'numeric' })}
              </p>
              <h2 class="font-heading text-xl font-extrabold leading-tight text-primary group-hover:text-accent-text sm:text-2xl">
                {article.data.title}
              </h2>
              <p class="text-sm leading-relaxed text-text-muted sm:text-base">
                {article.data.description}
              </p>
              <span class="mt-2 inline-flex items-center gap-2 text-sm font-semibold text-accent-text transition-all group-hover:gap-3">
                Read article &rarr;
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
