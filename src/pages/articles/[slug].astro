---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { site } from '../../config/site';
import { getAllProducts, formatPrice } from '../../utils/shopify';
import { shopifyImage } from '../../utils/shopifyImage';

export async function getStaticPaths() {
  const articles = await getCollection('articles', ({ data }) => !data.draft);
  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);

// Resolve related products at build time so we can show real prices/images.
const allProducts = await getAllProducts(250);
const productMap = new Map(allProducts.map((p) => [p.handle, p]));
const relatedProducts = article.data.relatedProducts
  .map((handle) => productMap.get(handle))
  .filter((p): p is NonNullable<typeof p> => Boolean(p));

const canonicalUrl = `${site.domain}/articles/${article.id}/`;
const publishedISO = article.data.publishedAt.toISOString();
const updatedISO = article.data.updatedAt?.toISOString();

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  '@id': `${canonicalUrl}#article`,
  headline: article.data.title,
  description: article.data.description,
  url: canonicalUrl,
  datePublished: publishedISO,
  dateModified: updatedISO ?? publishedISO,
  inLanguage: 'en-AU',
  keywords: article.data.keywords.join(', '),
  author: { '@id': `${site.domain}/about#founder` },
  publisher: { '@id': `${site.domain}/#store` },
  isPartOf: { '@id': `${site.domain}/#website` },
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalUrl },
  ...(article.data.image && {
    image: { '@type': 'ImageObject', url: `${site.domain}${article.data.image}` },
  }),
};

// HowTo schema — only emitted for the install guide. The article uses
// `## Step N` headings under "Step 1 ... Step 6" so the step list mirrors
// what is rendered. Unlocks the HowTo rich-snippet treatment in Google when
// the page ranks; cheap win on a high-intent how-to query.
const howToSchema =
  article.id === 'how-to-install-a-bait-board'
    ? {
        '@context': 'https://schema.org',
        '@type': 'HowTo',
        '@id': `${canonicalUrl}#howto`,
        name: 'How to Install a Bait Board on an Australian Boat',
        description:
          'Step-by-step installation guide for a SeaKing fibreglass bait board on a typical Australian fishing vessel — tools, hardware, mounting position, sealant, and final fit-up.',
        totalTime: 'PT2H30M',
        author: { '@id': `${site.domain}/about#founder` },
        tool: [
          { '@type': 'HowToTool', name: 'Drill with cobalt or HSS twist drill bit set' },
          { '@type': 'HowToTool', name: 'Measuring tape and spirit level' },
          { '@type': 'HowToTool', name: 'Caulking gun' },
          { '@type': 'HowToTool', name: 'Vacuum cleaner' },
          { '@type': 'HowToTool', name: 'Masking tape and isopropyl alcohol' },
        ],
        supply: [
          { '@type': 'HowToSupply', name: '316 marine-grade stainless steel bolts, washers, and nylock nuts' },
          { '@type': 'HowToSupply', name: 'Stainless backing plates or large-diameter penny washers' },
          { '@type': 'HowToSupply', name: 'Marine-grade polyurethane sealant (Sikaflex 291 or 3M 4000UV)' },
          { '@type': 'HowToSupply', name: 'Anti-seize compound for stainless bolt threads (optional)' },
        ],
        step: [
          {
            '@type': 'HowToStep',
            position: 1,
            name: 'Choose the mounting position',
            text: 'Mount the board where you actually fish, not where it looks tidiest from outside the boat. Check access, clearance from other gear, transom-door swing, and that the proposed structural attachment point is solid (tap-test for hollows).',
          },
          {
            '@type': 'HowToStep',
            position: 2,
            name: 'Mark and measure carefully',
            text: 'Place the board exactly where it will mount and mark each bolt hole through the mounting holes. Cross-check measurements from a fixed reference point so the board sits square to the boat centreline. Centre-punch each drill point.',
          },
          {
            '@type': 'HowToStep',
            position: 3,
            name: 'Drill the bolt holes',
            text: 'Use a bit slightly larger than the bolt diameter (bolt + 1 mm for stainless in fibreglass). Drill at low speed with steady pressure. Mask the drill point first to prevent gelcoat chipping. Vacuum holes thoroughly.',
          },
          {
            '@type': 'HowToStep',
            position: 4,
            name: 'Seal the holes',
            text: 'Run a heavy bead of marine polyurethane sealant inside each hole and around the underside of the board mounting flanges. Bolt through immediately so sealant displaces around the bolt threads and squeezes out at the joint. Wipe excess within 30 minutes.',
          },
          {
            '@type': 'HowToStep',
            position: 5,
            name: 'Install the bolts',
            text: 'Drop a stainless bolt with washer through each hole from the top. From underneath use a penny washer or backing plate, then nylock nut. Hand-tighten all bolts first, then cross-pattern snug-plus-a-quarter-turn.',
          },
          {
            '@type': 'HowToStep',
            position: 6,
            name: 'Final checks',
            text: 'Check the board sits flat and level with a spirit level in both directions. Test all rod holders, drain fittings, and accessories. Wait 24 hours for sealant cure before stress-testing.',
          },
        ],
      }
    : null;

const pageSchemas = howToSchema ? [articleSchema, howToSchema] : articleSchema;
---

<BaseLayout
  title={`${article.data.title} | Bait Boards Direct`}
  description={article.data.description}
  canonical={canonicalUrl}
  schema={pageSchemas}
  ogType="article"
>

  <!-- Article header -->
  <section class="bg-dark-hero py-14 text-white">
    <div class="container max-w-3xl">
      <p class="mb-2 text-xs font-semibold uppercase tracking-widest text-accent">
        <a href="/" class="hover:underline">Home</a> &rsaquo;
        <a href="/articles/" class="hover:underline">Articles</a>
      </p>
      <h1 class="font-heading text-3xl font-extrabold leading-tight sm:text-4xl">
        {article.data.title}
      </h1>
      <p class="mt-4 text-sm text-white/70">
        Published {article.data.publishedAt.toLocaleDateString('en-AU', { year: 'numeric', month: 'long', day: 'numeric' })}
        {article.data.updatedAt && ` · Updated ${article.data.updatedAt.toLocaleDateString('en-AU', { year: 'numeric', month: 'long', day: 'numeric' })}`}
        · By <a href="/about#founder" class="text-accent underline underline-offset-2">Harry, Bait Boards Direct</a>
      </p>
    </div>
  </section>

  <!-- Article body -->
  <section class="bg-white py-12 sm:py-16">
    <div class="container max-w-3xl">
      <article class="article-prose">
        <Content />
      </article>

      {relatedProducts.length > 0 && (
        <aside class="mt-16 rounded-2xl border border-border bg-bg-alt p-6 sm:p-8">
          <h2 class="font-heading mb-6 text-2xl font-extrabold text-primary">Featured in this article</h2>
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {relatedProducts.map((p) => (
              <a
                href={`/products/${p.handle}?utm_source=articles&utm_medium=internal&utm_campaign=related-products&utm_content=${article.id}`}
                class="group block overflow-hidden rounded-xl border border-border bg-white transition hover:shadow-md"
              >
                <div class="aspect-square overflow-hidden bg-bg-alt">
                  <img
                    src={shopifyImage(p.image, 400)}
                    alt={p.title}
                    class="h-full w-full object-cover transition-transform group-hover:scale-105"
                    width="400"
                    height="400"
                    loading="lazy"
                  />
                </div>
                <div class="p-4">
                  <h3 class="font-heading text-sm font-bold leading-snug text-primary line-clamp-2">{p.title}</h3>
                  <p class="mt-2 text-sm font-bold text-[#07272e]">{formatPrice(p.price)}</p>
                </div>
              </a>
            ))}
          </div>
        </aside>
      )}

      <div class="mt-12 text-center">
        <a href="/articles/" class="button">&larr; Back to all articles</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style is:global>
  .article-prose {
    color: var(--color-text-muted, #4B5563);
  }

  .article-prose h2 {
    font-family: 'Bricolage Grotesque', sans-serif;
    font-size: 1.65rem;
    font-weight: 800;
    line-height: 1.2;
    letter-spacing: -0.025em;
    color: #07272e;
    margin: 3rem 0 1rem 0;
    padding-bottom: 0.4rem;
    border-bottom: 2px solid rgba(0,0,0,0.08);
  }

  .article-prose h3 {
    font-family: 'Bricolage Grotesque', sans-serif;
    font-size: 1.2rem;
    font-weight: 700;
    color: #07272e;
    margin: 2rem 0 0.6rem 0;
  }

  .article-prose p {
    font-size: 1rem;
    line-height: 1.75;
    color: #4B5563;
    margin-bottom: 1.1rem;
  }

  .article-prose strong { color: #07272e; font-weight: 700; }

  .article-prose a {
    color: #008c9e;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
    transition: color 0.15s;
  }
  .article-prose a:hover { color: #07272e; }

  .article-prose ul,
  .article-prose ol {
    margin: 1rem 0 1.4rem 0;
    padding-left: 1.4rem;
  }

  .article-prose ul li,
  .article-prose ol li {
    font-size: 1rem;
    line-height: 1.7;
    color: #4B5563;
    margin-bottom: 0.4rem;
  }

  .article-prose ul li { list-style: disc; }
  .article-prose ol li { list-style: decimal; }

  .article-prose table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0 2rem 0;
    font-size: 0.95rem;
    border-radius: 0.5rem;
    overflow: hidden;
    box-shadow: 0 1px 2px rgba(0,0,0,0.06);
  }

  .article-prose table thead {
    background: #07272e;
    color: white;
  }

  .article-prose table th,
  .article-prose table td {
    padding: 0.75rem 1rem;
    text-align: left;
    border-bottom: 1px solid rgba(0,0,0,0.08);
  }

  .article-prose table th {
    font-weight: 700;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .article-prose table tbody tr:nth-child(even) { background: #f7f7f7; }

  .article-prose blockquote {
    border-left: 4px solid #008c9e;
    background: #f7f7f7;
    padding: 1rem 1.25rem;
    margin: 1.5rem 0;
    font-style: italic;
    border-radius: 0 0.5rem 0.5rem 0;
  }

  .article-prose code {
    background: #f3f4f6;
    padding: 0.15rem 0.4rem;
    border-radius: 0.3rem;
    font-family: monospace;
    font-size: 0.9em;
  }
</style>
