---
import BaseLayout from "../../layouts/BaseLayout.astro";
import NotFoundLayout from "../../layouts/NotFoundLayout.astro";
import AddToCartForm from "../../components/AddToCartForm.svelte";
import ProductReviews from "../../components/ProductReviews.astro";
import { getAllProducts, formatPrice } from "../../utils/shopify";
import { shopifyImage } from "../../utils/shopifyImage";

export async function getStaticPaths() {
  const products = await getAllProducts(250);

  // Build a small accessory pool once, then attach up to 3 per bait-board PDP.
  // Accessory match: anything not a "bait board" whose title contains a known
  // accessory keyword. Cheap heuristic; fine for the current catalogue (~22
  // active SKUs). Out-of-stock accessories are excluded so we never push a
  // dead cross-sell.
  const isBaitBoardTitle = (t: string) => /bait board/i.test(t);
  const isAccessoryTitle = (t: string) =>
    !isBaitBoardTitle(t) &&
    /rod holder|leaning post|leg|mount|upgrade|stainless steel mounting/i.test(t);
  const accessoryPool = products.filter(
    (p) => isAccessoryTitle(p.title) && p.availableForSale,
  );

  return products.map((p) => {
    const accessories = isBaitBoardTitle(p.title)
      ? accessoryPool.filter((a) => a.handle !== p.handle).slice(0, 3)
      : [];
    return {
      params: { handle: p.handle },
      props: { product: p, accessories },
    };
  });
}

const { product, accessories } = Astro.props;

// Build-time Judge.me fetch — parallel: product (schema AggregateRating) + reviews (display).
// Both fail gracefully; schema omits AggregateRating and component shows empty state.
let jmRating: number | null = null;
let jmReviewCount = 0;
let jmReviews: any[] = [];
const jmToken = import.meta.env.JUDGEME_API_TOKEN;
if (jmToken) {
  const shopDomain = 'd26601.myshopify.com';
  const [prodRes, revRes] = await Promise.allSettled([
    fetch(`https://judge.me/api/v1/products/-1?api_token=${jmToken}&shop_domain=${shopDomain}&handle=${product.handle}`),
    fetch(`https://judge.me/api/v1/reviews?api_token=${jmToken}&shop_domain=${shopDomain}&handle=${product.handle}&per_page=20&page=1`),
  ]);
  try {
    if (prodRes.status === 'fulfilled' && prodRes.value.ok) {
      const d = await prodRes.value.json();
      if (d?.product?.reviews_count > 0) {
        jmRating = d.product.rating;
        jmReviewCount = d.product.reviews_count;
      }
    }
  } catch { /* skip */ }
  try {
    if (revRes.status === 'fulfilled' && revRes.value.ok) {
      const d = await revRes.value.json();
      jmReviews = d?.reviews ?? [];
    }
  } catch { /* skip */ }
}

const onSale = product.compareAtPrice && product.compareAtPrice > product.price;
const savePct = onSale && product.compareAtPrice
  ? Math.round((1 - product.price / product.compareAtPrice) * 100)
  : 0;

// SEO title + description: prefer Shopify SEO metafields if set (managed via the
// SEO update pipeline in scripts/seo/), fall back to a built-from-title formula
// when the metafield is empty. This way the metafield is the source-of-truth for
// SEO experimentation and the formula is just a sensible default.
const lowerTitle = product.title.toLowerCase();
const isBaitBoard = /bait board/i.test(lowerTitle);
const isLegMount = isBaitBoard && /leaning post|\bskl[-\s]/i.test(lowerTitle);
const isAccessory = !isBaitBoard && /rod holder|leaning post|leg|mount|upgrade|stainless steel mounting/i.test(lowerTitle);
// Transom-mount bait boards = bait boards that aren't leg-mount. Used to
// auto-inject a "see all transom-mount" cross-link below the description,
// directing equity to /collections/transom-mount-bait-boards from the
// PDPs that fit it (most of the SeaKing range except the SKL series).
const isTransomMount = isBaitBoard && !isLegMount;
const titleQualifier = isLegMount
  ? 'Fibreglass Leg-Mount'
  : isAccessory
  ? 'Marine Accessory'
  : null;
const fallbackTitle = titleQualifier
  ? `${product.title} | ${titleQualifier} | Bait Boards Direct`
  : `${product.title} | Bait Boards Direct`;
const title = (product.seo?.title && product.seo.title.trim()) || fallbackTitle;

const descriptionPrefix = isAccessory
  ? 'Premium 316 marine-grade stainless steel accessory for SeaKing bait boards. '
  : 'Premium fibreglass bait board with 316 marine stainless rod holders, integrated sink and free Australia-wide shipping. ';
const fallbackDescription = (descriptionPrefix + product.description).slice(0, 160);
const description = (product.seo?.description && product.seo.description.trim()) || fallbackDescription;

const priceValidUntil = new Date(Date.now() + 365 * 24 * 60 * 60 * 1000).toISOString().split('T')[0];

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "@id": `https://baitboardsdirect.com/products/${product.handle}`,
  name: product.title,
  sku: product.handle,
  image: [product.image, ...(product.image2 ? [product.image2] : [])],
  description: product.description,
  brand: { "@type": "Brand", name: "SeaKing" },
  offers: {
    "@type": "Offer",
    url: `https://baitboardsdirect.com/products/${product.handle}`,
    priceCurrency: "AUD",
    price: product.price,
    priceValidUntil,
    availability: product.availableForSale ? "https://schema.org/InStock" : "https://schema.org/OutOfStock",
    itemCondition: "https://schema.org/NewCondition",
    seller: { "@id": "https://baitboardsdirect.com/#store" },
    shippingDetails: {
      "@type": "OfferShippingDetails",
      shippingRate: { "@type": "MonetaryAmount", value: "0", currency: "AUD" },
      shippingDestination: { "@type": "DefinedRegion", addressCountry: "AU" },
      deliveryTime: {
        "@type": "ShippingDeliveryTime",
        handlingTime: { "@type": "QuantitativeValue", minValue: 1, maxValue: 3, unitCode: "DAY" },
        transitTime: { "@type": "QuantitativeValue", minValue: 3, maxValue: 7, unitCode: "DAY" },
      },
    },
    hasMerchantReturnPolicy: {
      "@type": "MerchantReturnPolicy",
      applicableCountry: "AU",
      returnPolicyCategory: "https://schema.org/MerchantReturnFiniteReturnWindow",
      merchantReturnDays: 30,
      returnMethod: "https://schema.org/ReturnByMail",
      returnFees: "https://schema.org/OriginalShippingFees",
    },
  },
  ...(jmRating !== null && {
    aggregateRating: {
      "@type": "AggregateRating",
      ratingValue: jmRating.toFixed(1),
      reviewCount: jmReviewCount,
      bestRating: "5",
      worstRating: "1",
    },
  }),
};
---

<BaseLayout title={title} description={description} schema={productSchema} preloadImage={shopifyImage(product.image, 1200)} preloadImageMobile={shopifyImage(product.image, 600)} ogType="product" productMeta={{ price: product.price, priceCurrency: 'AUD', availability: product.availableForSale ? 'instock' : 'outofstock' }}>

  <!-- Breadcrumb -->
  <div class="border-b border-border bg-bg-alt">
    <div class="container py-3">
      <p class="text-xs text-text-muted">
        <a href="/" class="hover:text-accent-text transition-colors">Home</a>
        &rsaquo;
        <a href="/collections/bait-boards" class="hover:text-accent-text transition-colors">Bait Boards</a>
        &rsaquo;
        <span class="text-primary">{product.title}</span>
      </p>
    </div>
  </div>

  <!-- Product detail -->
  <section class="bg-white py-12 sm:py-16">
    <div class="container">
      <div class="grid gap-10 lg:grid-cols-2 lg:gap-16">

        <!-- Image gallery -->
        <div>
          <div class="relative overflow-hidden rounded-2xl bg-bg-alt" style="aspect-ratio: 1 / 1;">
            {onSale && savePct > 0 && (
              <span class="absolute top-3 left-3 z-10 rounded-none bg-[#07272e] px-2.5 py-1 text-xs font-bold text-white leading-tight">
                Save {savePct}%
              </span>
            )}
            <img
              id="gallery-main"
              src={shopifyImage(product.image, 1200)}
              srcset={`${shopifyImage(product.image, 600)} 600w, ${shopifyImage(product.image, 1200)} 1200w`}
              sizes="(max-width: 767px) 100vw, 600px"
              alt={product.title}
              class="h-full w-full object-cover transition-opacity duration-200"
              width="600"
              height="600"
              fetchpriority="high"
              loading="eager"
              decoding="async"
            />
          </div>
          {product.image2 && (
            <div class="mt-3 flex gap-2">
              <button
                class="gallery-thumb h-16 w-16 shrink-0 overflow-hidden rounded-lg border-2 border-accent bg-bg-alt transition-colors"
                data-src={shopifyImage(product.image, 1200)}
                data-srcset={`${shopifyImage(product.image, 600)} 600w, ${shopifyImage(product.image, 1200)} 1200w`}
                aria-label="View image 1"
              >
                <img src={shopifyImage(product.image, 128)} alt={`${product.title} — image 1`} class="h-full w-full object-cover" width="64" height="64" loading="eager" />
              </button>
              <button
                class="gallery-thumb h-16 w-16 shrink-0 overflow-hidden rounded-lg border-2 border-border bg-bg-alt transition-colors hover:border-accent"
                data-src={shopifyImage(product.image2, 1200)}
                data-srcset={`${shopifyImage(product.image2, 600)} 600w, ${shopifyImage(product.image2, 1200)} 1200w`}
                aria-label="View image 2"
              >
                <img src={shopifyImage(product.image2, 128)} alt={`${product.title} — image 2`} class="h-full w-full object-cover" width="64" height="64" loading="lazy" />
              </button>
            </div>
          )}
        </div>
        <script is:inline>
          (function () {
            var main = document.getElementById('gallery-main');
            if (!main) return;
            document.querySelectorAll('.gallery-thumb').forEach(function (btn) {
              btn.addEventListener('click', function () {
                // Update srcset FIRST so the browser's responsive image
                // selection picks the right width before src triggers a load.
                if (btn.dataset.srcset) main.srcset = btn.dataset.srcset;
                main.src = btn.dataset.src;
                document.querySelectorAll('.gallery-thumb').forEach(function (b) {
                  b.classList.remove('border-accent');
                  b.classList.add('border-border');
                });
                btn.classList.remove('border-border');
                btn.classList.add('border-accent');
              });
            });
          })();
        </script>

        <!-- Info -->
        <div class="flex flex-col">
          <h1 class="font-heading text-2xl font-bold leading-tight text-primary sm:text-3xl">
            {product.title}
          </h1>

          <div class="mt-4 flex flex-wrap items-center gap-3">
            <span class="text-2xl font-bold text-[#07272e]">
              {formatPrice(product.price)}
            </span>
            {onSale && product.compareAtPrice && (
              <>
                <span class="text-base text-text-muted line-through">
                  {formatPrice(product.compareAtPrice)}
                </span>
                {savePct > 0 && (
                  <span class="rounded-none bg-[#07272e] px-2 py-0.5 text-xs font-bold text-white leading-tight">
                    Save {savePct}%
                  </span>
                )}
              </>
            )}
          </div>

          {/* Low-stock urgency — only when ≥1 unit but ≤5 left. Quantities >5
              don't display (avoids "33 in stock" oversupply signal); zero/sold
              out is handled by the Sold out button on the add-to-cart form. */}
          {product.availableForSale && product.quantityAvailable > 0 && product.quantityAvailable <= 5 && (
            <p class="mt-3 inline-flex items-center gap-2 rounded-full bg-[#fef2e9] px-3 py-1 text-xs font-bold text-[#c2410c]" role="status">
              <span aria-hidden="true">⚡</span>
              Only {product.quantityAvailable} left in stock
            </p>
          )}

          {/* Mobile-priority reorder: trust → ATC sit ABOVE description on
              mobile (order-4 + order-5) so the Add to Cart button is closer
              to the fold. On desktop the natural reading order is preserved
              (description → trust → ATC) via lg:order-* overrides. */}
          <div class="order-7 lg:order-4 mt-6 border-t border-gray-200 pt-6">
            <p class="text-sm leading-relaxed text-text-muted sm:text-base">
              {product.description}
            </p>
            {isTransomMount && (
              <p class="mt-3 text-sm">
                <a href="/collections/transom-mount-bait-boards" class="font-bold text-[#008c9e] underline underline-offset-2 hover:text-[#07272e]">
                  &rarr; Browse all transom-mount bait boards
                </a>
              </p>
            )}
            {isLegMount && (
              <p class="mt-3 text-sm">
                <a href="/collections/bait-boards-with-legs" class="font-bold text-[#008c9e] underline underline-offset-2 hover:text-[#07272e]">
                  &rarr; Browse all leg-mount bait boards
                </a>
              </p>
            )}
          </div>

          <!-- Trust signals — concrete specifics over boilerplate. -->
          <ul class="order-4 lg:order-5 mt-6 space-y-1.5 text-sm text-gray-600">
            <li class="flex items-start gap-2">
              <span class="font-bold text-[#008c9e]">✓</span> Free shipping Australia-wide — no minimum order
            </li>
            <li class="flex items-start gap-2">
              <span class="font-bold text-[#008c9e]">✓</span> 30-day returns + 1-year warranty on every SeaKing board
            </li>
            <li class="flex items-start gap-2">
              <span class="font-bold text-[#008c9e]">✓</span> Handcrafted in Melbourne by a 20-year fibreglass craftsman
            </li>
            <li class="flex items-start gap-2">
              <span class="font-bold text-[#008c9e]">✓</span> Ships within 1-3 business days
            </li>
          </ul>

          <!-- Add to cart -->
          <div class="order-5 lg:order-6 mt-8" id="sticky-atc-target">
            <AddToCartForm
              client:visible
              variantId={product.variantId}
              variantQuantityAvailable={product.quantityAvailable}
              variantAvailableForSale={product.availableForSale}
              productId={product.handle}
              productName={product.title}
              productPrice={product.price}
              productHandle={product.handle}
              productBrand="SeaKing"
            />
          </div>

          {/* Cross-domain checkout reassurance — sits directly under ATC.
              Shopify checkout runs on baitboardsdirect.myshopify.com so the
              domain switch needs trust scaffolding (Baymard: ~3-7% abandon on
              cross-domain checkout). Banner names the platform + wallets at
              the decision point. */}
          <div class="order-6 lg:order-7 mt-3 flex items-start gap-2 rounded-lg bg-[#f7f7f7] px-3 py-2.5 text-xs leading-snug text-text-muted">
            <span aria-hidden="true" class="mt-0.5 flex-shrink-0">🔒</span>
            <span>
              Secure checkout powered by <strong class="font-bold text-[#07272e]">Shopify Pay</strong> (PCI Level 1).
              Apple Pay, Google Pay &amp; Afterpay accepted.
            </span>
          </div>

          <a
            href="/collections/bait-boards"
            class="order-8 mt-5 text-center text-sm text-text-muted underline underline-offset-2 transition-colors hover:text-primary"
          >
            &larr; Back to Bait Boards
          </a>
        </div>
      </div>
    </div>
  </section>

  {/* Complete your setup — accessory cross-sells. Only renders on bait-board
      PDPs (accessories is empty array for non-bait-board pages, so the
      section short-circuits). Pool built once in getStaticPaths; up to 3
      shown per page. */}
  {accessories.length > 0 && (
    <section class="border-t border-gray-200 bg-white py-12 sm:py-14">
      <div class="container">
        <h2 class="font-heading mb-2 text-2xl font-bold text-[#07272e] sm:text-3xl">
          Complete your setup
        </h2>
        <p class="mb-8 max-w-2xl text-sm leading-relaxed text-text-muted sm:text-base">
          Marine-grade accessories that pair with your SeaKing bait board — built from the same 316 stainless and composite materials.
        </p>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {accessories.map((a) => (
            <a
              href={`/products/${a.handle}`}
              class="group block rounded-2xl border border-gray-200 bg-white p-4 transition hover:border-[#008c9e] hover:shadow-md"
            >
              <div class="mb-3 aspect-square overflow-hidden rounded-xl bg-bg-alt">
                <img
                  src={shopifyImage(a.image, 400)}
                  alt={a.title}
                  class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                  width="400"
                  height="400"
                  loading="lazy"
                />
              </div>
              <h3 class="font-heading line-clamp-2 text-sm font-bold text-[#07272e] group-hover:text-[#008c9e]">
                {a.title}
              </h3>
              <p class="mt-2 text-sm font-bold text-[#07272e]">{formatPrice(a.price)}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Why Choose Our Bait Boards -->
  <section class="bg-[#f7f7f7] py-14">
    <div class="container">
      <div class="grid gap-10 md:grid-cols-2 md:items-start">
        <div>
          <img
            src={shopifyImage(product.image, 1200)}
            alt={product.title}
            width="1200"
            height="1200"
            class="w-full rounded-xl"
            loading="lazy"
          />
        </div>
        <div>
          <h2 class="font-heading mb-4 text-3xl font-bold text-[#07272e]">
            Why Choose Our Bait Boards
          </h2>
          <p class="mb-6 leading-relaxed text-gray-600">
            Made to last and super easy to use, our bait boards are the perfect fishing buddy.
            Lightweight, rust-proof, and built with durable fiberglass, they're ready for any
            boat and every catch.
          </p>
          <ul class="divide-y divide-gray-200">
            {[
              { title: 'Fiberglass Materials', desc: 'Crafted from durable fiberglass for lightweight strength, impact resistance, and long-lasting performance.' },
              { title: 'Built-in Cutting Surface', desc: 'Durable and hygienic cutting surface, perfect for preparing bait or cleaning your catch.' },
              { title: 'Easy Installation', desc: 'Universal mounting system fits most boats. Install and remove in minutes.' },
              { title: 'Rust-Resistant', desc: 'Crafted with premium materials to withstand saltwater and harsh marine environments.' },
            ].map(f => (
              <li class="py-4">
                <p class="font-bold text-[#07272e]">{f.title}</p>
                <p class="mt-1 text-sm leading-relaxed text-gray-600">{f.desc}</p>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust badges row -->
  <section class="border-b border-t border-gray-200 bg-white py-4">
    <div class="container overflow-x-auto">
      <ul class="flex min-w-max items-center justify-center gap-8 list-none p-0 m-0">
        {[
          '🚚 Free shipping Australia-wide, no minimum',
          '⚡ Dispatched within 1–3 business days',
          '🇦🇺 Handcrafted in Melbourne by a 20-year fibreglass craftsman',
          '🛡️ 1-year warranty + 30-day returns',
          '🔒 Secure Shopify Pay — Apple Pay, Google Pay, Afterpay',
        ].map(b => (
          <li class="whitespace-nowrap text-xs font-bold uppercase tracking-widest text-[#07272e]">{b}</li>
        ))}
      </ul>
    </div>
  </section>

  <!-- FAQ section -->
  <section class="bg-white py-14">
    <div class="container max-w-3xl">
      <h2 class="font-heading mb-8 text-3xl font-bold text-[#07272e]">FAQs</h2>
      <div class="divide-y divide-gray-200">
        {[
          { q: 'Can I use the bait board in saltwater environments?', a: 'Absolutely! Our fiberglass bait boards are specifically crafted for saltwater use, with corrosion-resistant components that ensure long-lasting performance.' },
          { q: 'Are replacement parts available?', a: 'We stock replacement parts including rod holders and drainage plugs. Contact us directly to inquire about specific parts.' },
          { q: 'What size bait board is best for my boat?', a: 'Check the dimensions listed on each product page and compare with your setup. Our range covers 600mm to 830mm width to suit everything from a tinnie to a large centre console.' },
          { q: 'Do you ship bait boards internationally?', a: 'Yes, we offer international shipping. Delivery times and costs vary by location — check our Shipping Policy or contact us for details.' },
          { q: "Can I return a product if it's damaged during shipping?", a: "If your bait board arrives damaged, contact us immediately with photos of the damage and we'll assist with a replacement or refund per our Return and Refund Policy." },
        ].map(item => (
          <details class="group py-4">
            <summary class="flex cursor-pointer items-center justify-between font-bold text-[#07272e]">
              {item.q}
              <span class="ml-4 flex-shrink-0 text-lg text-[#008c9e] transition-transform group-open:rotate-45">+</span>
            </summary>
            <p class="mt-3 text-sm leading-relaxed text-gray-600">{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Related guides -->
  <section class="bg-[#f7f7f7] py-14">
    <div class="container">
      <h2 class="font-heading mb-8 text-3xl font-bold text-[#07272e]">Related guides</h2>
      <div class="grid gap-6 sm:grid-cols-3">
        {[
          { href: '/articles/how-to-choose-a-bait-board-for-your-boat', title: 'How to choose a bait board for your boat', desc: 'Size, mounting style, rod holders — what actually matters.' },
          { href: '/articles/how-to-install-a-bait-board', title: 'How to install a bait board', desc: 'Step-by-step transom and leg-mount installation guide.' },
          { href: '/articles/fibreglass-vs-aluminium-bait-boards', title: 'Fibreglass vs aluminium bait boards', desc: 'Materials, durability, and which to pick for your setup.' },
        ].map(g => (
          <a
            href={g.href}
            class="group block rounded-2xl border border-gray-200 bg-white p-6 transition hover:border-[#008c9e] hover:shadow-md"
          >
            <h3 class="font-heading mb-2 text-base font-bold text-[#07272e] group-hover:text-[#008c9e]">
              {g.title}
            </h3>
            <p class="text-sm leading-relaxed text-gray-600">{g.desc}</p>
            <span class="mt-3 inline-block text-xs font-bold uppercase tracking-widest text-[#008c9e]">Read guide &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <ProductReviews handle={product.handle} reviews={jmReviews} rating={jmRating} reviewCount={jmReviewCount} />

  {/* Sticky mobile add-to-cart bar — appears once the in-page AddToCartForm
      scrolls out of view (above the viewport). Hidden on desktop. */}
  <div
    id="sticky-atc-sentinel"
    class="h-1 w-1"
    aria-hidden="true"
    data-sticky-atc-sentinel
  ></div>

  <div
    id="sticky-atc-bar"
    class="md:hidden fixed bottom-0 inset-x-0 z-50 translate-y-full transition-transform duration-300 ease-out bg-white border-t border-gray-200 shadow-[0_-4px_16px_rgba(0,0,0,0.08)]"
    aria-hidden="true"
    inert
  >
    <div class="container max-w-3xl flex items-center justify-between gap-3 py-3">
      <div class="flex-shrink min-w-0">
        <p class="text-xs font-bold text-[#07272e] truncate leading-tight">{product.title.replace(/\s*&\s*\d+\s*Game Rated Rod Holders\s*/i, '').trim()}</p>
        <p class="text-base font-bold text-[#07272e] leading-tight">{formatPrice(product.price)}</p>
      </div>
      <a
        href="#sticky-atc-target"
        class="flex-shrink-0 rounded-full bg-[#008c9e] px-5 py-2.5 text-xs font-bold uppercase tracking-widest text-white transition-colors hover:bg-[#07272e]"
        data-sticky-atc-cta
      >Add to cart</a>
    </div>
  </div>

  {/* GA4 page-data — read by the single bundled script in BaseLayout.
      Kept as type="application/json" so it's CSP-exempt and adds no hash. */}
  <script type="application/json" id="ga4-page-data" set:html={JSON.stringify({
    event: 'view_item',
    item: {
      item_id: product.handle,
      item_name: product.title,
      price: product.price,
      item_brand: 'SeaKing',
    },
  })} />

  <script is:inline>
    (function () {
      var sentinel = document.getElementById('sticky-atc-sentinel');
      var bar = document.getElementById('sticky-atc-bar');
      if (!sentinel || !bar || !('IntersectionObserver' in window)) return;
      // Reveal the bar when the sentinel is scrolled OUT of view above the
      // viewport (i.e. user has scrolled past the in-page Add to Cart).
      var observer = new IntersectionObserver(function (entries) {
        var entry = entries[0];
        var aboveViewport = !entry.isIntersecting && entry.boundingClientRect.top < 0;
        bar.classList.toggle('translate-y-full', !aboveViewport);
        bar.setAttribute('aria-hidden', aboveViewport ? 'false' : 'true');
        // Sync `inert` with aria-hidden so the focusable <a> inside the bar
        // is removed from keyboard tab order while the bar is off-screen.
        // (aria-hidden alone hides from assistive tech but doesn't affect
        // tab order — keyboard users would otherwise focus an invisible link.)
        if (aboveViewport) bar.removeAttribute('inert');
        else bar.setAttribute('inert', '');
      }, { threshold: 0 });
      observer.observe(sentinel);
    })();
  </script>

</BaseLayout>
