---
import BaseLayout from '../layouts/BaseLayout.astro';
import { FISHING_OPTIONS, BOAT_OPTIONS, RODS_OPTIONS } from '../utils/quiz';

const title = "Help Me Choose a Bait Board | Bait Boards Direct";
const description = "Three quick questions and we'll point you to the SeaKing bait board that suits your boat, your fishing style, and your rod setup. Built by Harry — 20 years of fibreglass craftsmanship.";

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How does the help-me-choose tool work?',
      acceptedAnswer: { '@type': 'Answer', text: 'Three quick questions about your fishing style, boat size, and rod setup. We match your answers to the SeaKing model that fits — a working fibreglass boat builder picked the recommendations.' },
    },
    {
      '@type': 'Question',
      name: 'Can I see all bait boards instead?',
      acceptedAnswer: { '@type': 'Answer', text: 'Yes — head to /collections/bait-boards for the full SeaKing range with prices, dimensions, and descriptions on each product page.' },
    },
  ],
};
---

<BaseLayout title={title} description={description} schema={faqSchema}>

  <!-- Hero -->
  <section class="bg-dark-hero py-16 text-white">
    <div class="container max-w-3xl text-center">
      <p class="mb-3 text-xs font-semibold uppercase tracking-widest text-accent">Help Me Choose</p>
      <h1 class="font-heading mb-4 text-3xl font-extrabold sm:text-5xl">Find Your Bait Board in 30 Seconds</h1>
      <p class="text-base leading-relaxed text-white/80 sm:text-lg">
        Three quick questions. We'll match you to the SeaKing model that fits your boat and fishing style — picked by Harry, who has been building fibreglass marine gear for 20 years.
      </p>
    </div>
  </section>

  <!-- Quiz form -->
  <section class="bg-white py-14 sm:py-20">
    <div class="container max-w-3xl">
      <form id="bbd-quiz" class="space-y-10">

        <fieldset>
          <legend class="font-heading mb-4 text-xl font-bold text-primary sm:text-2xl">1. What kind of fishing do you do most?</legend>
          <div class="space-y-3">
            {FISHING_OPTIONS.map((opt) => (
              <label class="quiz-opt flex cursor-pointer items-start gap-3 rounded-xl border-2 border-border bg-white p-4 transition hover:border-accent">
                <input type="radio" name="fishing" value={opt.value} class="mt-1 h-4 w-4 accent-[#008c9e]" required />
                <span>
                  <span class="block font-bold text-primary">{opt.label}</span>
                  <span class="mt-1 block text-sm text-text-muted">{opt.hint}</span>
                </span>
              </label>
            ))}
          </div>
        </fieldset>

        <fieldset>
          <legend class="font-heading mb-4 text-xl font-bold text-primary sm:text-2xl">2. How long is your boat?</legend>
          <div class="space-y-3">
            {BOAT_OPTIONS.map((opt) => (
              <label class="quiz-opt flex cursor-pointer items-start gap-3 rounded-xl border-2 border-border bg-white p-4 transition hover:border-accent">
                <input type="radio" name="boat" value={opt.value} class="mt-1 h-4 w-4 accent-[#008c9e]" required />
                <span>
                  <span class="block font-bold text-primary">{opt.label}</span>
                  <span class="mt-1 block text-sm text-text-muted">{opt.hint}</span>
                </span>
              </label>
            ))}
          </div>
        </fieldset>

        <fieldset>
          <legend class="font-heading mb-4 text-xl font-bold text-primary sm:text-2xl">3. How many rod holders do you need?</legend>
          <div class="space-y-3">
            {RODS_OPTIONS.map((opt) => (
              <label class="quiz-opt flex cursor-pointer items-start gap-3 rounded-xl border-2 border-border bg-white p-4 transition hover:border-accent">
                <input type="radio" name="rods" value={opt.value} class="mt-1 h-4 w-4 accent-[#008c9e]" required />
                <span>
                  <span class="block font-bold text-primary">{opt.label}</span>
                  <span class="mt-1 block text-sm text-text-muted">{opt.hint}</span>
                </span>
              </label>
            ))}
          </div>
        </fieldset>

        <div class="flex flex-col items-center gap-4 pt-4">
          <button type="submit" class="button-accent w-full sm:w-auto">See My Recommendation</button>
          <noscript>
            <p class="text-sm text-text-muted">JavaScript is required to compute your recommendation. <a href="/collections/bait-boards" class="underline">Browse all bait boards</a> instead.</p>
          </noscript>
        </div>
      </form>
    </div>
  </section>

  <script is:inline>
    (function () {
      var form = document.getElementById('bbd-quiz');
      if (!form) return;
      form.addEventListener('submit', function (e) {
        e.preventDefault();
        var fd = new FormData(form);
        var fishing = fd.get('fishing');
        var boat = fd.get('boat');
        var rods = fd.get('rods');
        if (!fishing || !boat || !rods) return;
        window.location.href = '/help-me-choose/result/' + fishing + '-' + boat + '-' + rods + '/';
      });
    })();
  </script>

  <!-- Trust block -->
  <section class="bg-bg-alt py-14">
    <div class="container max-w-3xl text-center">
      <h2 class="font-heading mb-4 text-2xl font-bold text-primary">Why trust the recommendation?</h2>
      <p class="text-sm leading-relaxed text-text-muted sm:text-base">
        The matrix behind this tool was built by Harry, our founder and a working fibreglass boat builder with over 20 years of experience. He has handled, mounted, and tested every model we sell. The board you'll see at the end is the one he'd put on your boat.
      </p>
      <a href="/about#founder" class="mt-6 inline-block button-accent">Read Harry's story</a>
    </div>
  </section>

</BaseLayout>
