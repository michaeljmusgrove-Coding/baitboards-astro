---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../config/site';

const title = "Privacy Policy | Bait Boards Direct";
const description = "Privacy policy for Bait Boards Direct. How we collect, use, and protect your personal information.";
---

<BaseLayout title={title} description={description}>
  <section class="bg-bg-alt py-16 sm:py-20">
    <div class="container max-w-3xl">
      <h1 class="font-heading mb-8 text-3xl font-bold text-primary sm:text-4xl">Privacy Policy</h1>
      <div class="prose max-w-none policy-content text-text-muted space-y-6 text-sm leading-relaxed">

        <p>This Privacy Policy describes how {site.name} ("we", "us", or "our") collects, uses, and shares information about you when you use our website at {site.domain}.</p>

        <h2 class="font-heading text-xl font-bold text-primary">Information We Collect</h2>
        <ul class="list-disc pl-5 space-y-1">
          <li><strong>Order information:</strong> name, billing/shipping address, email, phone number, and payment details (processed securely by Shopify Payments — we never store full card numbers).</li>
          <li><strong>Account information:</strong> if you create an account, we store your email and order history.</li>
          <li><strong>Usage data:</strong> pages visited, browser type, device information, and IP address (collected by Google Analytics and Microsoft Clarity).</li>
          <li><strong>Communications:</strong> emails and enquiries you send us.</li>
        </ul>

        <h2 class="font-heading text-xl font-bold text-primary">How We Use Your Information</h2>
        <ul class="list-disc pl-5 space-y-1">
          <li>To process and fulfil your orders</li>
          <li>To send order confirmation and shipping notifications</li>
          <li>To respond to enquiries and provide customer support</li>
          <li>To improve our website and product range</li>
          <li>To send marketing communications (with your consent)</li>
        </ul>

        <h2 class="font-heading text-xl font-bold text-primary">Sharing Your Information</h2>
        <p>We do not sell your personal information. We share data only with service providers necessary to operate our business (Shopify for ecommerce, courier services for delivery, Google for analytics). All providers are bound by data processing agreements.</p>

        <h2 class="font-heading text-xl font-bold text-primary">Cookies</h2>
        <p>We use cookies to maintain cart sessions and collect analytics data. You can disable cookies in your browser settings, though some site features may not function correctly.</p>

        <h2 class="font-heading text-xl font-bold text-primary">Your Rights</h2>
        <p>Under Australian Privacy law you have the right to access, correct, or request deletion of your personal data. To exercise these rights, contact us at <a href="/contact" class="text-primary underline underline-offset-2 hover:text-accent-text transition-colors">our contact page</a>.</p>

        <h2 class="font-heading text-xl font-bold text-primary">Contact</h2>
        <p>Questions about this policy? <a href="/contact" class="text-primary underline underline-offset-2 hover:text-accent-text transition-colors">Contact us</a> and we'll respond within 5 business days.</p>

        <p class="text-xs text-text-muted/70 pt-4 border-t border-border">Last updated: May 2026</p>
      </div>
    </div>
  </section>
</BaseLayout>
