---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getAllProducts, formatPrice } from '../utils/shopify';
import { shopifyImage } from '../utils/shopifyImage';
import { site } from '../config/site';

const title = "Bait Boards for Tinnies — Compact Fibreglass Boards for Small Boats | Bait Boards Direct";
const description = "Premium fibreglass bait boards designed for tinnies, kayaks, and small boats under 5m. Compact 600–700mm widths, integrated sinks, 316 stainless rod holders, free Australia-wide shipping.";

// Compact bait-board models suited to tinnies and small boats.
const TINNIE_HANDLES = [
  'bait-board-jj-12',     // 600 x 350mm — smallest in range
  'bait-board-hh-14',     // 625 x 390mm — compact with cup holders
  'bait-board-sk-j07',    // 700 x 420mm — sleek mid-compact
  'bait-board-sk-k08-blk',// 700 x 420mm — black variant
  'bait-board-b01',       // 650 x 430mm — classic with rod holders
  'bait-board-b02',       // 650 x 430mm — with cup holders
  'bait-board-sq-13',     // 700 x 350mm — compact with tackle compartments
];

const allProducts = await getAllProducts(250);
const products = TINNIE_HANDLES
  .map(h => allProducts.find(p => p.handle === h))
  .filter((p): p is NonNullable<typeof p> => Boolean(p));

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': `${site.domain}/bait-boards-for-tinnies/`,
  name: 'Bait Boards for Tinnies',
  url: `${site.domain}/bait-boards-for-tinnies/`,
  description,
  isPartOf: { '@id': `${site.domain}/#website` },
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: products.map((p, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: `${site.domain}/products/${p.handle}`,
      name: p.title,
    })),
  },
};
---

<BaseLayout title={title} description={description} schema={schema}>

  <!-- Hero -->
  <section class="bg-dark-hero py-14 text-white">
    <div class="container">
      <p class="mb-2 text-xs font-bold uppercase tracking-widest text-accent-on-dark">
        <a href="/" class="hover:underline">Home</a> &rsaquo; Bait Boards for Tinnies
      </p>
      <h1 class="font-heading text-3xl font-bold sm:text-4xl" style="font-style:normal; text-transform:none;">Bait Boards for Tinnies & Small Boats</h1>
      <p class="mt-3 max-w-2xl text-sm leading-relaxed text-white/70">
        Compact 600–700mm fibreglass bait boards designed for tinnies, kayaks, and small runabouts under 5 metres. Same SeaKing build quality as our larger boards — integrated sinks, 316 marine stainless hardware, UV-resistant cutting surface — sized to fit a small deck without dominating it.
      </p>
    </div>
  </section>

  <!-- Why a smaller board for a tinnie -->
  <section class="bg-white py-12 sm:py-16">
    <div class="container max-w-3xl">
      <h2 class="font-heading mb-6 text-2xl font-bold text-[#07272e] sm:text-3xl" style="font-style:normal; text-transform:none;">Why a smaller bait board makes sense on a tinnie</h2>
      <div class="space-y-4 text-sm leading-relaxed text-text-muted sm:text-base">
        <p>
          The biggest mistake first-time bait-board buyers make on a tinnie is sizing up. A 900mm offshore-grade board is overkill for a 4m runabout — it consumes deck space, makes movement awkward, and doesn't actually improve your fishing. The right bait board for a small boat sits in the 600–700mm range, leaves clearance for movement, and integrates a working surface that handles the catch sizes typical for inshore and estuary fishing.
        </p>
        <p>
          Every board in this collection is designed for that brief. Compact footprint, full SeaKing build quality, and the same composite fibreglass construction that lasts decades on larger vessels. <a href="/contact" class="text-accent-text underline underline-offset-2 hover:text-primary">Contact us</a> if you want a model match based on your specific boat, or browse the picks below.
        </p>
      </div>
    </div>
  </section>

  <!-- Product grid -->
  <section class="bg-white pb-12 sm:pb-16">
    <div class="container">
      <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
        {products.map((product) => {
          const onSale = product.compareAtPrice && product.compareAtPrice > product.price;
          const soldOut = !product.availableForSale;
          const savePct = onSale && product.compareAtPrice
            ? Math.round((1 - product.price / product.compareAtPrice) * 100)
            : 0;
          return (
            <a
              href={`/products/${product.handle}`}
              class="group block rounded bg-[rgba(0,0,0,0.03)] overflow-hidden transition hover:shadow-md"
            >
              <div class="relative aspect-square overflow-hidden bg-[rgba(0,0,0,0.03)]">
                {onSale && savePct > 0 && (
                  <span class="absolute top-2 left-2 z-10 rounded-none bg-[#07272e] px-2 py-0.5 text-xs font-bold text-white leading-tight">
                    Save {savePct}%
                  </span>
                )}
                <img
                  src={shopifyImage(product.image, 400)}
                  alt={product.title}
                  class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                  width="400"
                  height="400"
                  loading="lazy"
                />
              </div>
              <div class="p-3 sm:p-4">
                <h3 class="font-heading text-xs font-bold leading-snug text-primary line-clamp-2 sm:text-sm">
                  {product.title}
                </h3>
                <div class="mt-2 flex items-center gap-2 flex-wrap">
                  <span class="text-sm font-bold text-[#07272e]">{formatPrice(product.price)}</span>
                  {onSale && product.compareAtPrice && (
                    <span class="text-xs text-text-muted line-through">{formatPrice(product.compareAtPrice)}</span>
                  )}
                </div>
              </div>
              <div class="px-3 pb-3 sm:px-4 sm:pb-4">
                {soldOut ? (
                  <button disabled class="w-full cursor-not-allowed rounded-full bg-gray-400 py-2 text-xs font-bold uppercase tracking-widest text-white">Sold out</button>
                ) : (
                  <button class="w-full rounded-full bg-[#008c9e] py-2 text-xs font-bold uppercase tracking-widest text-white transition-colors hover:bg-[#07272e]">View product</button>
                )}
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- SEO content block -->
  <section class="border-t border-gray-200 bg-[#f7f7f7] py-14">
    <div class="container max-w-3xl">
      <h2 class="font-heading mb-6 text-2xl font-bold text-[#07272e]" style="font-style:normal; text-transform:none;">Tinnie-friendly bait boards built to last</h2>
      <div class="space-y-4 text-sm leading-relaxed text-gray-600">
        <p>
          The SeaKing range we supply at Bait Boards Direct is handcrafted from full composite fibreglass — the same material used in marine vessel hull construction. That means a board that doesn't warp, swell, rot, or delaminate in the saltwater and UV environment Australian boats live in. The hardware is 316 marine-grade stainless steel throughout, including rod holders, drain fittings, and mounting bolts.
        </p>
        <p>
          Boards in this collection are sized for vessels under 5 metres — kayaks, tinnies, small runabouts, and inflatables. Each one includes an integrated sink with drain fitting, UV-resistant PE plastic cutting surface, and game-rated rod holders where the model includes them. Smaller doesn't mean compromised — it means right-sized.
        </p>
        <ul class="mt-2 space-y-1 list-none pl-0">
          <li>✓ 600–700mm widths suited to tinnies and small runabouts</li>
          <li>✓ Composite fibreglass shell — handles saltwater UV without breaking down</li>
          <li>✓ Integrated sink with drain fitting on every model</li>
          <li>✓ 316 marine-grade stainless steel hardware throughout</li>
          <li>✓ Free shipping Australia-wide, 30-day returns, 1-year warranty</li>
        </ul>
        <p class="mt-6">
          Need help picking the right model? Read the buyer's guide on <a href="/articles/how-to-choose-a-bait-board-for-your-boat" class="text-accent-text underline underline-offset-2 hover:text-primary">how to choose a bait board for your boat</a>, or <a href="/contact" class="text-accent-text underline underline-offset-2 hover:text-primary">contact us</a> with your boat details.
        </p>
      </div>
    </div>
  </section>

</BaseLayout>
