---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getByCollection, formatPrice } from '../../data/products';

const title = "Bait Boards | Bait Boards Direct";
const description = "Check out our premium bait boards, perfect for making your fishing trips smoother and more fun. Our bait boards are built tough and super practical.";

const products = getByCollection('bait-boards');
---

<BaseLayout title={title} description={description}>

  <!-- Collection header -->
  <section class="bg-dark-hero py-14 text-white">
    <div class="container">
      <p class="mb-2 text-xs font-semibold uppercase tracking-widest text-accent">
        <a href="/" class="hover:underline">Home</a> &rsaquo; Collection
      </p>
      <h1 class="font-heading text-3xl font-extrabold sm:text-4xl">Bait Boards</h1>
      <p class="mt-3 max-w-2xl text-sm leading-relaxed text-white/70">
        Check out our premium bait boards, perfect for making your fishing trips smoother and more fun. Our bait boards are built tough and super practical — they'll handle all your bait prep and cleaning with ease.
      </p>
    </div>
  </section>

  <!-- Product grid -->
  <section class="bg-white py-12 sm:py-16">
    <div class="container">
      <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
        {products.map((product) => {
          const onSale = product.compareAtPrice && product.compareAtPrice > product.price;
          return (
            <a
              href={`/products/${product.handle}`}
              class="group block rounded-xl border border-border bg-white overflow-hidden transition hover:shadow-md"
            >
              <div class="relative aspect-square overflow-hidden bg-bg-alt">
                {onSale && (
                  <span class="absolute top-2 left-2 z-10 rounded bg-sale px-2 py-0.5 text-xs font-bold text-white">
                    SALE
                  </span>
                )}
                <img
                  src={product.image}
                  alt={product.title}
                  class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                  width="400"
                  height="400"
                  loading="lazy"
                />
              </div>
              <div class="p-3 sm:p-4">
                <h2 class="font-heading text-xs font-semibold leading-snug text-primary line-clamp-2 sm:text-sm">
                  {product.title}
                </h2>
                <div class="mt-2 flex items-center gap-2 flex-wrap">
                  <span class={`text-sm font-bold ${onSale ? 'text-sale' : 'text-primary'}`}>
                    {formatPrice(product.price)}
                  </span>
                  {onSale && product.compareAtPrice && (
                    <span class="text-xs text-text-muted line-through">
                      {formatPrice(product.compareAtPrice)}
                    </span>
                  )}
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

</BaseLayout>
