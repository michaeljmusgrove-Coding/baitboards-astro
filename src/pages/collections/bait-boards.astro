---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollectionWithMeta, formatPrice } from '../../utils/shopify';
import { shopifyImage } from '../../utils/shopifyImage';
import { site } from '../../config/site';

const collection = await getCollectionWithMeta({ handle: 'bait-boards' });
const products = collection?.products ?? [];

// Prefer Shopify SEO metafields (managed via scripts/seo/5-apply-collections.mjs),
// fall back to hardcoded values if the metafield is unset.
// Title + description weave in the "boat bait board" head-term cluster
// (`bait boards for boats`, `bait board for boat`, `boat bait board` —
// 610/mo combined AU volume — surfaced by the 2026-05-20 competitor audit
// where all 3 direct competitors capture this with simple title/H1 moves).
const fallbackTitle = "Bait Boards for Boats — Premium Fibreglass Range Australia | Bait Boards Direct";
const fallbackDescription = "Bait boards for boats — premium fibreglass SeaKing range with integrated sinks, 316 marine stainless hardware, and game-rated rod holders on the B-series. Free Australia-wide shipping, 1-year warranty on every board.";
const title = collection?.seo.title?.trim() || fallbackTitle;
const description = collection?.seo.description?.trim() || fallbackDescription;

// Price-range computed at build time from the live Shopify catalogue.
// Drives the AggregateOffer block below, which gives Google a "from $X"
// SERP hint on this collection page (Day 4 schema audit M4).
const inStockPrices = products
  .filter((p) => p.availableForSale && typeof p.price === 'number' && p.price > 0)
  .map((p) => p.price);
const lowPrice = inStockPrices.length ? Math.min(...inStockPrices) : null;
const highPrice = inStockPrices.length ? Math.max(...inStockPrices) : null;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': `${site.domain}/collections/bait-boards`,
  name: 'Bait Boards',
  url: `${site.domain}/collections/bait-boards`,
  image: `${site.domain}/images/collection-bait-boards.webp`,
  description,
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: products.map((p, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: `${site.domain}/products/${p.handle}`,
      name: p.title,
    })),
  },
  ...(lowPrice !== null && highPrice !== null && {
    offers: {
      '@type': 'AggregateOffer',
      priceCurrency: 'AUD',
      lowPrice: lowPrice.toFixed(2),
      highPrice: highPrice.toFixed(2),
      offerCount: products.length,
      availability: 'https://schema.org/InStock',
    },
  }),
};
---

<BaseLayout title={title} description={description} schema={schema}>

  <!-- Collection header -->
  <section class="bg-dark-hero py-14 text-white">
    <div class="container">
      <p class="mb-2 text-xs font-bold uppercase tracking-widest text-accent-on-dark">
        <a href="/" class="hover:underline">Home</a> &rsaquo; Bait Boards
      </p>
      <h1 class="font-heading text-3xl font-extrabold sm:text-4xl" style="font-style:normal; text-transform:none;">Bait Boards for Boats — Premium Fibreglass Range</h1>
      <p class="mt-3 max-w-2xl text-sm leading-relaxed text-white/70">
        The complete range of fibreglass bait boards for boats — built tough for offshore, inshore, and estuary fishing on Australian vessels. Every boat bait board in the SeaKing range carries a composite fibreglass shell, integrated sink with drain, and 316 marine-grade stainless steel hardware.
      </p>
    </div>
  </section>

  {/* Filter pills — drive equity to curated feature subsets. Each pill is
      its own crawlable URL with curated content, not a query-string facet
      (faceted nav doesn't index well; distinct URLs do). */}
  <section class="border-b border-gray-200 bg-white py-5">
    <div class="container">
      <div class="flex flex-wrap items-center gap-2 sm:gap-3">
        <span class="text-xs font-bold uppercase tracking-widest text-text-muted mr-2">Shop by feature:</span>
        <a href="/collections/bait-boards-with-rod-holders" class="rounded-full border border-border bg-white px-3 py-1.5 text-xs font-bold text-[#07272e] transition-colors hover:border-[#008c9e] hover:text-[#008c9e]">With rod holders</a>
        <a href="/collections/bait-boards-with-cup-holders" class="rounded-full border border-border bg-white px-3 py-1.5 text-xs font-bold text-[#07272e] transition-colors hover:border-[#008c9e] hover:text-[#008c9e]">With cup holders</a>
        <a href="/bait-boards-for-tinnies" class="rounded-full border border-border bg-white px-3 py-1.5 text-xs font-bold text-[#07272e] transition-colors hover:border-[#008c9e] hover:text-[#008c9e]">For tinnies</a>
        <a href="/collections/transom-mount-bait-boards" class="rounded-full border border-border bg-white px-3 py-1.5 text-xs font-bold text-[#07272e] transition-colors hover:border-[#008c9e] hover:text-[#008c9e]">Transom mount</a>
        <a href="/collections/bait-boards-with-legs" class="rounded-full border border-border bg-white px-3 py-1.5 text-xs font-bold text-[#07272e] transition-colors hover:border-[#008c9e] hover:text-[#008c9e]">Leg mount</a>
        <a href="/aluminium-vs-fibreglass-bait-boards" class="rounded-full border border-border bg-white px-3 py-1.5 text-xs font-bold text-[#07272e] transition-colors hover:border-[#008c9e] hover:text-[#008c9e]">Aluminium vs Fibreglass</a>
      </div>
    </div>
  </section>

  <!-- Product grid -->
  <section class="bg-white py-12 sm:py-16">
    <div class="container">
      <h2 class="sr-only">SeaKing bait board range</h2>
      <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
        {products.map((product, index) => {
          const onSale = product.compareAtPrice && product.compareAtPrice > product.price;
          const soldOut = !product.availableForSale;
          const savePct = onSale && product.compareAtPrice
            ? Math.round((1 - product.price / product.compareAtPrice) * 100)
            : 0;
          const isAboveFold = index < 2;
          return (
            <a
              href={`/products/${product.handle}`}
              class="group block rounded bg-[rgba(0,0,0,0.03)] overflow-hidden transition hover:shadow-md"
            >
              <div class="relative aspect-square overflow-hidden bg-[rgba(0,0,0,0.03)]">
                {onSale && savePct > 0 && (
                  <span class="absolute top-2 left-2 z-10 rounded-none bg-[#07272e] px-2 py-0.5 text-xs font-bold text-white leading-tight">
                    Save {savePct}%
                  </span>
                )}
                {product.availableForSale && product.quantityAvailable > 0 && product.quantityAvailable <= 5 && (
                  <span class="absolute top-2 right-2 z-10 rounded-full bg-[#c2410c] px-2 py-0.5 text-[10px] font-bold uppercase tracking-wide text-white leading-tight">
                    Only {product.quantityAvailable} left
                  </span>
                )}
                <img
                  src={shopifyImage(product.image, 400)}
                  alt={product.title}
                  class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                  width="400"
                  height="400"
                  loading={isAboveFold ? "eager" : "lazy"}
                  fetchpriority={index === 0 ? "high" : "auto"}
                />
              </div>
              <div class="p-3 sm:p-4">
                <h3 class="font-heading text-xs font-bold leading-snug text-primary line-clamp-2 sm:text-sm">
                  {product.title}
                </h3>
                <div class="mt-2 flex items-center gap-2 flex-wrap">
                  <span class="text-sm font-bold text-[#07272e]">
                    {formatPrice(product.price)}
                  </span>
                  {onSale && product.compareAtPrice && (
                    <span class="text-xs text-text-muted line-through">
                      {formatPrice(product.compareAtPrice)}
                    </span>
                  )}
                </div>
              </div>
              <div class="px-3 pb-3 sm:px-4 sm:pb-4">
                {soldOut ? (
                  <button
                    disabled
                    class="w-full cursor-not-allowed rounded-full bg-gray-400 py-2 text-xs font-bold uppercase tracking-widest text-white"
                  >
                    Sold out
                  </button>
                ) : (
                  <button
                    class="w-full rounded-full bg-[#008c9e] py-2 text-xs font-bold uppercase tracking-widest text-white transition-colors hover:bg-[#07272e]"
                  >
                    Add to cart
                  </button>
                )}
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  {/* GA4 page-data read by the bundled script in BaseLayout (CSP-exempt JSON). */}
  <script type="application/json" id="ga4-page-data" set:html={JSON.stringify({
    event: 'view_item_list',
    list_id: 'collection-bait-boards',
    list_name: 'Bait Boards',
    items: products.map((p, i) => ({
      item_id: p.handle,
      item_name: p.title,
      price: p.price,
      index: i,
      item_brand: 'SeaKing',
    })),
  })} />

  <!-- SEO text block -->
  <section class="border-t border-gray-200 bg-[#f7f7f7] py-14">
    <div class="container max-w-3xl">
      <h2 class="font-heading mb-6 text-2xl font-extrabold text-[#07272e]">
        Bait Boards for Every Boat — Tinnie to Offshore Centre Console
      </h2>

      {/* Microformat answer block — scannable bullet summary at the top of
          the body copy gives AI Overviews + Perplexity passage-extractors a
          single citable chunk for "what makes a SeaKing bait board" queries.
          Matches Day 4 GEO audit recommendation M2 (passage-level citability).
      */}
      <div class="mb-8 rounded-2xl border border-[#008c9e]/20 bg-white p-5 sm:p-6">
        <p class="mb-3 text-xs font-bold uppercase tracking-widest text-accent-text">What makes a SeaKing bait board</p>
        <ul class="space-y-2 text-sm leading-relaxed text-[#07272e] sm:text-base">
          <li><strong>Composite fibreglass shell</strong> — marine-grade gelcoat, UV-stable, electrochemically inert.</li>
          <li><strong>316 marine stainless hardware</strong> — bolts, rod-holder bases, drain fittings; no galvanic failure mode.</li>
          <li><strong>Integrated sink + drain</strong> — moulded into the shell during manufacture, not bolted on.</li>
          <li><strong>Australian-made</strong> — handcrafted in Melbourne by a working fibreglass boat builder.</li>
          <li><strong>1-year warranty + free AU-wide shipping</strong> — every board, every order.</li>
        </ul>
      </div>

      <div class="space-y-4 text-sm leading-relaxed text-gray-600">
        <p>
          Whether you need a compact boat bait board for a tinnie or a 900mm offshore-grade
          setup with integrated rod holders, the SeaKing range covers every Australian fishing
          rig. Every board is built from full composite fibreglass — the same material used in
          marine hull construction — with 316 marine-grade stainless steel hardware throughout.
          For smaller vessels, see our <a href="/bait-boards-for-tinnies" class="text-accent-text underline underline-offset-2 hover:text-primary">bait boards for tinnies</a> range.
        </p>
        <p>
          Not sure whether fibreglass or aluminium is right for your boat? Read our detailed
          <a href="/aluminium-vs-fibreglass-bait-boards" class="text-accent-text underline underline-offset-2 hover:text-primary">aluminium vs fibreglass bait boards comparison</a> covering weight,
          durability, hardware, and total cost over a 10-year ownership window. For boards
          that come with rod holders included, the <a href="/collections/bait-boards-with-rod-holders" class="text-accent-text underline underline-offset-2 hover:text-primary">B-series rod-holder
          range</a> is purpose-built — game-rated 316 stainless holders, integrated through
          the fibreglass shell to transfer marlin/tuna drag load through the board structure.
        </p>
        <ul class="mt-2 space-y-1 list-none pl-0">
          <li>✓ Bait boards for boats from 4m tinnies to 7m+ offshore vessels</li>
          <li>✓ Composite fibreglass shell — handles saltwater UV without degrading</li>
          <li>✓ Integrated sink + drain fitting on every board (no retrofit needed)</li>
          <li>✓ 316 marine-grade stainless hardware throughout</li>
          <li>✓ Game-rated rod holders included on the B-series; standalone holders available for other models</li>
          <li>✓ Free Australia-wide shipping, 30-day returns, 1-year warranty</li>
        </ul>
      </div>
    </div>
  </section>

</BaseLayout>
