---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllProducts, formatPrice } from '../../utils/shopify';
import { shopifyImage } from '../../utils/shopifyImage';
import { site } from '../../config/site';

const title = "Bait Boards with Cup Holders — Moulded-in Marine Storage | Bait Boards Direct";
const description = "Fibreglass bait boards with cup holders moulded into the shell. Seven SeaKing models from compact tinnie boards to full leg-mount. Free Australia-wide shipping.";

// Seven SeaKing models with cup holders moulded into the composite shell
// during manufacture — not bolt-on aftermarket. The cup holder doubles as a
// rod-rest, knife-handle holder, or burley-pot location during deck work.
const CUP_HOLDER_HANDLES = [
  'bait-board-b02',     // 650 x 430mm + rod holders + cup holders
  'bait-board-b04',     // 830 x 430mm + rod holders + cup holders
  'bait-board-hh-14',   // 625 x 390mm compact
  'bait-board-hj-15',   // 700 x 415mm mid
  'bait-board-jj-12',   // 600 x 350mm compact (smallest)
  'bait-board-skl-s05', // 720 x 500mm leg-mount
  'bait-board-skl-l06', // 900 x 500mm leg-mount (largest)
];

const allProducts = await getAllProducts(250);
const products = CUP_HOLDER_HANDLES
  .map((h) => allProducts.find((p) => p.handle === h))
  .filter((p): p is NonNullable<typeof p> => Boolean(p));

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': `${site.domain}/collections/bait-boards-with-cup-holders`,
  name: 'Bait Boards with Cup Holders',
  url: `${site.domain}/collections/bait-boards-with-cup-holders`,
  description,
  isPartOf: { '@id': `${site.domain}/#website` },
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: products.map((p, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: `${site.domain}/products/${p.handle}`,
      name: p.title,
    })),
  },
};
---

<BaseLayout title={title} description={description} schema={schema}>

  <!-- Hero -->
  <section class="bg-dark-hero py-14 text-white">
    <div class="container">
      <p class="mb-2 text-xs font-semibold uppercase tracking-widest text-accent-on-dark">
        <a href="/" class="hover:underline">Home</a> &rsaquo;
        <a href="/collections/bait-boards" class="hover:underline">Bait Boards</a> &rsaquo;
        With Cup Holders
      </p>
      <h1 class="font-heading text-3xl font-extrabold sm:text-4xl" style="font-style:normal; text-transform:none;">
        Bait Boards with Cup Holders
      </h1>
      <p class="mt-3 max-w-2xl text-sm leading-relaxed text-white/70">
        Seven SeaKing models with cup holders moulded into the composite shell — not bolt-on add-ons. Keep drinks, knife handles, burley pots, or rod butts to hand without losing deck space.
      </p>
    </div>
  </section>

  <!-- Why moulded-in cup holders matter -->
  <section class="bg-white py-12 sm:py-16">
    <div class="container max-w-3xl">
      <h2 class="font-heading mb-6 text-2xl font-extrabold text-[#07272e] sm:text-3xl" style="font-style:normal; text-transform:none;">Moulded-in vs bolted-on cup holders</h2>
      <div class="space-y-4 text-sm leading-relaxed text-text-muted sm:text-base">
        <p>
          A cup holder bolted to the surface of a bait board sits proud, fills with bait residue and salt, and lifts the cutting plane. Moulded-in cup holders are recessed into the fibreglass shell during manufacture — flush with the deck, easy to rinse, and impossible to crack off in chop.
        </p>
        <p>
          Practically, the cup holder gets used for more than drinks. A coke can goes in, sure — but most days it's a knife handle keeping the blade off the deck, a burley pot during berleying, a sinker pocket while rigging, or a rod butt rest when re-baiting. The Australian fishing pattern is that whatever fits in the cup holder lives in the cup holder.
        </p>
        <p>
          Sizing range here covers everything: the JJ-12 (600 × 350mm) is the smallest board in our catalogue and suits a 4m tinnie; the SKL-L06 (900 × 500mm) is our largest, sized for offshore centre consoles. Whatever your boat, there's a board on this page with cup holders moulded in.
        </p>
      </div>
    </div>
  </section>

  <!-- Product grid -->
  <section class="bg-white pb-12 sm:pb-16">
    <div class="container">
      <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
        {products.map((product, index) => {
          const onSale = product.compareAtPrice && product.compareAtPrice > product.price;
          const soldOut = !product.availableForSale;
          const savePct = onSale && product.compareAtPrice
            ? Math.round((1 - product.price / product.compareAtPrice) * 100)
            : 0;
          const isAboveFold = index < 2;
          return (
            <a
              href={`/products/${product.handle}`}
              class="group block rounded bg-[rgba(0,0,0,0.03)] overflow-hidden transition hover:shadow-md"
            >
              <div class="relative aspect-square overflow-hidden bg-[rgba(0,0,0,0.03)]">
                {onSale && savePct > 0 && (
                  <span class="absolute top-2 left-2 z-10 rounded-none bg-[#07272e] px-2 py-0.5 text-xs font-bold text-white leading-tight">
                    Save {savePct}%
                  </span>
                )}
                {product.availableForSale && product.quantityAvailable > 0 && product.quantityAvailable <= 5 && (
                  <span class="absolute top-2 right-2 z-10 rounded-full bg-[#c2410c] px-2 py-0.5 text-[10px] font-bold uppercase tracking-wide text-white leading-tight">
                    Only {product.quantityAvailable} left
                  </span>
                )}
                <img
                  src={shopifyImage(product.image, 400)}
                  alt={product.title}
                  class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                  width="400"
                  height="400"
                  loading={isAboveFold ? "eager" : "lazy"}
                  fetchpriority={index === 0 ? "high" : "auto"}
                />
              </div>
              <div class="p-3 sm:p-4">
                <h3 class="font-heading text-xs font-semibold leading-snug text-primary line-clamp-2 sm:text-sm">
                  {product.title}
                </h3>
                <div class="mt-2 flex items-center gap-2 flex-wrap">
                  <span class="text-sm font-bold text-[#07272e]">{formatPrice(product.price)}</span>
                  {onSale && product.compareAtPrice && (
                    <span class="text-xs text-text-muted line-through">{formatPrice(product.compareAtPrice)}</span>
                  )}
                </div>
              </div>
              <div class="px-3 pb-3 sm:px-4 sm:pb-4">
                {soldOut ? (
                  <button disabled class="w-full cursor-not-allowed rounded-full bg-gray-400 py-2 text-xs font-bold uppercase tracking-widest text-white">Sold out</button>
                ) : (
                  <button class="w-full rounded-full bg-[#008c9e] py-2 text-xs font-bold uppercase tracking-widest text-white transition-colors hover:bg-[#07272e]">View product</button>
                )}
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Upward link to parent collection hub — keyword-anchor internal link
       to concentrate authority on /collections/bait-boards (the topically
       canonical page for "bait board" / "bait boards" head terms). -->
  <section class="border-t border-gray-200 bg-white py-10">
    <div class="container max-w-3xl text-center">
      <p class="text-sm text-text-muted sm:text-base">
        Need a transom-mount, leg-mount, or compact tinnie-sized board? <a href="/collections/bait-boards" class="font-semibold text-accent-text underline underline-offset-2 hover:text-primary">Browse the full SeaKing bait board range</a> &mdash; every fibreglass model in the catalogue.
      </p>
    </div>
  </section>

  {/* GA4 page-data read by the bundled script in BaseLayout (CSP-exempt JSON). */}
  <script type="application/json" id="ga4-page-data" set:html={JSON.stringify({
    event: 'view_item_list',
    list_id: 'collection-bait-boards-with-cup-holders',
    list_name: 'Bait Boards with Cup Holders',
    items: products.map((p, i) => ({
      item_id: p.handle,
      item_name: p.title,
      price: p.price,
      index: i,
      item_brand: 'SeaKing',
    })),
  })} />

</BaseLayout>
