---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllProducts, formatPrice } from '../../utils/shopify';
import { shopifyImage } from '../../utils/shopifyImage';
import { site } from '../../config/site';

const title = "Bait Boards with Rod Holders — Game-Rated SeaKing B-Series | Bait Boards Direct";
const description = "SeaKing B-series fibreglass bait boards with game-rated rod holders integrated through the composite shell — for marlin, tuna, kingfish. Free AU shipping.";

// The B-series — every model in this list ships with 2 game-rated 316 marine
// stainless rod holders as part of the board, NOT bolted on afterwards. The
// holders are reinforced through the fibreglass shell so trolling load
// transfers into the board structure rather than concentrating at the mount.
// If you want rod holders on a non-B-series board, see the standalone
// /products/rod-holders accessory.
const ROD_HOLDER_HANDLES = [
  'bait-board-b01',  // 650 x 430mm
  'bait-board-b02',  // 650 x 430mm + cup holders
  'bait-board-b03',  // 830 x 430mm
  'bait-board-b04',  // 830 x 430mm + cup holders
];

const allProducts = await getAllProducts(250);
const products = ROD_HOLDER_HANDLES
  .map((h) => allProducts.find((p) => p.handle === h))
  .filter((p): p is NonNullable<typeof p> => Boolean(p));

const standaloneRodHolder = allProducts.find((p) => p.handle === 'rod-holders');

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': `${site.domain}/collections/bait-boards-with-rod-holders`,
  name: 'Bait Boards with Rod Holders',
  url: `${site.domain}/collections/bait-boards-with-rod-holders`,
  description,
  isPartOf: { '@id': `${site.domain}/#website` },
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: products.map((p, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: `${site.domain}/products/${p.handle}`,
      name: p.title,
    })),
  },
};
---

<BaseLayout title={title} description={description} schema={schema}>

  <!-- Hero -->
  <section class="bg-dark-hero py-14 text-white">
    <div class="container">
      <p class="mb-2 text-xs font-bold uppercase tracking-widest text-accent-on-dark">
        <a href="/" class="hover:underline">Home</a> &rsaquo;
        <a href="/collections/bait-boards" class="hover:underline">Bait Boards</a> &rsaquo;
        With Rod Holders
      </p>
      <h1 class="font-heading text-3xl font-extrabold sm:text-4xl" style="font-style:normal; text-transform:none;">
        Bait Boards with Rod Holders — SeaKing B-Series
      </h1>
      <p class="mt-3 max-w-2xl text-sm leading-relaxed text-white/70">
        Every board on this page ships with two game-rated 316 marine stainless rod holders integrated through the fibreglass shell — engineered for marlin, tuna, and kingfish drag loads, not a bolt-on aftermarket fit.
      </p>
    </div>
  </section>

  <!-- Why integrated rod holders matter -->
  <section class="bg-white py-12 sm:py-16">
    <div class="container max-w-3xl">
      <h2 class="font-heading mb-6 text-2xl font-extrabold text-[#07272e] sm:text-3xl" style="font-style:normal; text-transform:none;">Why an integrated rod holder beats a bolt-on</h2>
      <div class="space-y-4 text-sm leading-relaxed text-text-muted sm:text-base">
        <p>
          A rod holder bolted to the top of a bait board carries the entire trolling load through 4–6 small bolts and the laminate skin underneath them. Hook a serious pelagic and the load concentrates exactly there. Most aftermarket rod-holder failures we see in marine workshops are pull-through cracks at the bolt holes — not the rod holder itself.
        </p>
        <p>
          On the SeaKing B-series, the rod holder tubes are reinforced through the fibreglass shell during manufacture. The structural connection runs into the board itself, distributing drag load across the whole shell rather than concentrating at the surface fasteners. You get a properly engineered rig that handles the same loads as a transom rod holder, in a bait-board form factor.
        </p>
        <p>
          If you already own a SeaKing board without rod holders, we also stock the <a href="/products/rod-holders" class="text-accent-text underline underline-offset-2 hover:text-primary">standalone 316 stainless Game Rated Rod Holder</a> — same 316 marine grade, suited to retrofitting if your board has the structural backing for it. <a href="/contact" class="text-accent-text underline underline-offset-2 hover:text-primary">Contact us</a> with your board model and we'll confirm fit.
        </p>
      </div>
    </div>
  </section>

  <!-- Product grid -->
  <section class="bg-white pb-12 sm:pb-16">
    <div class="container">
      <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
        {products.map((product, index) => {
          const onSale = product.compareAtPrice && product.compareAtPrice > product.price;
          const soldOut = !product.availableForSale;
          const savePct = onSale && product.compareAtPrice
            ? Math.round((1 - product.price / product.compareAtPrice) * 100)
            : 0;
          const isAboveFold = index < 2;
          return (
            <a
              href={`/products/${product.handle}`}
              class="group block rounded bg-[rgba(0,0,0,0.03)] overflow-hidden transition hover:shadow-md"
            >
              <div class="relative aspect-square overflow-hidden bg-[rgba(0,0,0,0.03)]">
                {onSale && savePct > 0 && (
                  <span class="absolute top-2 left-2 z-10 rounded-none bg-[#07272e] px-2 py-0.5 text-xs font-bold text-white leading-tight">
                    Save {savePct}%
                  </span>
                )}
                {product.availableForSale && product.quantityAvailable > 0 && product.quantityAvailable <= 5 && (
                  <span class="absolute top-2 right-2 z-10 rounded-full bg-[#c2410c] px-2 py-0.5 text-[10px] font-bold uppercase tracking-wide text-white leading-tight">
                    Only {product.quantityAvailable} left
                  </span>
                )}
                <img
                  src={shopifyImage(product.image, 400)}
                  alt={product.title}
                  class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                  width="400"
                  height="400"
                  loading={isAboveFold ? "eager" : "lazy"}
                  fetchpriority={index === 0 ? "high" : "auto"}
                />
              </div>
              <div class="p-3 sm:p-4">
                <h3 class="font-heading text-xs font-bold leading-snug text-primary line-clamp-2 sm:text-sm">
                  {product.title}
                </h3>
                <div class="mt-2 flex items-center gap-2 flex-wrap">
                  <span class="text-sm font-bold text-[#07272e]">{formatPrice(product.price)}</span>
                  {onSale && product.compareAtPrice && (
                    <span class="text-xs text-text-muted line-through">{formatPrice(product.compareAtPrice)}</span>
                  )}
                </div>
              </div>
              <div class="px-3 pb-3 sm:px-4 sm:pb-4">
                {soldOut ? (
                  <button disabled class="w-full cursor-not-allowed rounded-full bg-gray-400 py-2 text-xs font-bold uppercase tracking-widest text-white">Sold out</button>
                ) : (
                  <button class="w-full rounded-full bg-[#008c9e] py-2 text-xs font-bold uppercase tracking-widest text-white transition-colors hover:bg-[#07272e]">View product</button>
                )}
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Upward link to parent collection hub — keyword-anchor internal link
       to concentrate authority on /collections/bait-boards (the topically
       canonical page for "bait board" / "bait boards" head terms). -->
  <section class="border-t border-gray-200 bg-white py-10">
    <div class="container max-w-3xl text-center">
      <p class="text-sm text-text-muted sm:text-base">
        Want a board without rod holders, or a leg-mount configuration? <a href="/collections/bait-boards" class="font-bold text-accent-text underline underline-offset-2 hover:text-primary">Browse the full SeaKing bait board range</a> &mdash; every fibreglass model in the catalogue.
      </p>
    </div>
  </section>

  {/* GA4 page-data read by the bundled script in BaseLayout (CSP-exempt JSON). */}
  <script type="application/json" id="ga4-page-data" set:html={JSON.stringify({
    event: 'view_item_list',
    list_id: 'collection-bait-boards-with-rod-holders',
    list_name: 'Bait Boards with Rod Holders',
    items: products.map((p, i) => ({
      item_id: p.handle,
      item_name: p.title,
      price: p.price,
      index: i,
      item_brand: 'SeaKing',
    })),
  })} />

  {/* Standalone rod-holder accessory cross-sell — for users who own a
      non-B-series board and want to upgrade. Genuine adjacent intent. */}
  {standaloneRodHolder && (
    <section class="border-t border-gray-200 bg-[#f7f7f7] py-14">
      <div class="container max-w-3xl">
        <h2 class="font-heading mb-4 text-2xl font-extrabold text-[#07272e]" style="font-style:normal; text-transform:none;">Already own a SeaKing board?</h2>
        <p class="mb-6 text-sm leading-relaxed text-text-muted sm:text-base">
          If you own a non-B-series SeaKing board and want to add rod holders, the standalone 316 marine stainless Game Rated Rod Holder is available separately. Same game-rated 316 stainless construction as the B-series integrated holders.
        </p>
        <a href={`/products/${standaloneRodHolder.handle}`} class="group flex items-center gap-4 rounded-2xl border border-gray-200 bg-white p-4 transition hover:border-[#008c9e] hover:shadow-md sm:p-6">
          <div class="h-24 w-24 flex-shrink-0 overflow-hidden rounded-xl bg-bg-alt">
            <img
              src={shopifyImage(standaloneRodHolder.image, 200)}
              alt={standaloneRodHolder.title}
              class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
              width="200"
              height="200"
              loading="lazy"
            />
          </div>
          <div class="flex-1">
            <h3 class="font-heading text-base font-extrabold text-[#07272e] group-hover:text-[#008c9e]">{standaloneRodHolder.title}</h3>
            <p class="mt-1 text-sm font-bold text-[#07272e]">{formatPrice(standaloneRodHolder.price)}</p>
            <span class="mt-2 inline-block text-xs font-bold uppercase tracking-widest text-[#008c9e]">View accessory &rarr;</span>
          </div>
        </a>
      </div>
    </section>
  )}

</BaseLayout>
