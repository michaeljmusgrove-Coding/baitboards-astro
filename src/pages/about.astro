---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "About Us | Bait Boards Direct";
const description = "We're all about quality, simplicity, and products that actually work. Based in South East Melbourne, supplying premium bait boards across Australia.";
---

<BaseLayout title={title} description={description} preloadImage="/images/about-boatyard.webp">

  <!-- Hero banner -->
  <section class="relative overflow-hidden bg-dark-hero" style="height: clamp(280px, 40vh, 440px);">
    <img
      src="/images/about-boatyard.webp"
      alt="Boat yard — Bait Boards Direct"
      class="h-full w-full object-cover object-center"
      width="1400"
      height="932"
      fetchpriority="high"
      loading="eager"
    />
    <div class="absolute inset-0 bg-black/50"></div>
    <div class="absolute inset-0 flex items-center justify-center">
      <h1 class="font-heading text-center text-4xl font-extrabold text-white sm:text-5xl">
        Welcome to Bait Boards Direct
      </h1>
    </div>
  </section>

  <!-- Main content -->
  <section class="bg-white py-16 sm:py-20">
    <div class="container max-w-3xl">
      <div class="space-y-5 text-sm leading-relaxed text-text-muted sm:text-base">
        <p>
          We know there's nothing better than a great day out on the water, but we also know that juggling bait, tackle, and gear can get messy. That's where we come in. At Bait Boards Direct we've made it our mission to keep things organised, so you can focus on what matters: catching your next big fish.
        </p>
        <p>
          We're all about quality, simplicity, and products that actually work. Our bait boards are designed by fishing enthusiasts who understand the struggles of real anglers. Whether you're a weekend warrior or a seasoned pro, we've got a bait board that'll make your setup smoother, cleaner, and more efficient.
        </p>
        <p>
          But it's not just about the products, it's about the experience. We're passionate about fishing, and everything we do is to help you make the most of your time on the water. From sunrise casts to sunset reels, we're here to support your adventures with gear that won't let you down.
        </p>
      </div>

      <div class="mt-10 rounded-2xl bg-bg-alt p-8">
        <h2 class="font-heading mb-3 text-xl font-bold text-primary">Our Mission</h2>
        <p class="text-sm leading-relaxed text-text-muted sm:text-base">
          Our mission is simple: to provide anglers with durable, reliable, and practical bait boards that make every fishing trip smoother and more enjoyable. We're here to support your passion for fishing with high-quality products designed by people who love the water as much as you do.
        </p>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="bg-bg-alt py-16 sm:py-20">
    <div class="container max-w-4xl">
      <h2 class="font-heading mb-10 text-center text-2xl font-bold text-primary sm:text-3xl">Our Values</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {[
          { title: 'Quality First', body: "We're committed to delivering top-notch bait boards that stand up to the toughest fishing conditions." },
          { title: 'Customer-Centric', body: "Your fishing experience is at the heart of everything we do. We listen, innovate, and deliver products you can trust." },
          { title: 'Passion for Fishing', body: "We share your love for the sport, and that passion drives us to create products that enhance your time on the water." },
          { title: 'Simplicity', body: "Fishing should be fun, not complicated. We design our bait boards to make your experience as smooth and hassle-free as possible." },
          { title: 'Reliability', body: "You can count on our products to perform, so you can focus on what you do best – fishing." },
        ].map(({ title: vt, body }) => (
          <div class="rounded-2xl border border-border bg-white p-6">
            <h3 class="font-heading mb-2 text-base font-bold text-primary">{vt}</h3>
            <p class="text-sm leading-relaxed text-text-muted">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <section class="bg-white py-16 sm:py-20">
    <div class="container max-w-3xl">
      <h2 class="font-heading mb-8 text-2xl font-bold text-primary sm:text-3xl">Common Questions</h2>
      <div class="space-y-3">
        {[
          {
            q: 'Where are you based?',
            a: "We're proudly based in South East Melbourne, Australia, providing high-quality bait boards to fishing enthusiasts across the country.",
          },
          {
            q: 'Do you offer bulk discounts for large orders?',
            a: "Yes, we do! If you're planning to place a large order, reach out to us, and we'll be happy to discuss bulk pricing options.",
          },
          {
            q: 'Do you have a physical store, or are you online-only?',
            a: "We're online-only to provide the best prices possible for our customers. This way, you get premium-quality bait boards without the added costs of a storefront.",
          },
          {
            q: 'Is there a warranty on your bait boards?',
            a: "Yes, all our bait boards come with a 1 year warranty to ensure your satisfaction. If you encounter any issues, just get in touch, and we'll make it right.",
          },
        ].map(({ q, a }) => (
          <details class="group rounded-xl border border-border bg-bg-alt">
            <summary class="flex cursor-pointer items-center justify-between px-5 py-4 font-heading text-sm font-semibold text-primary">
              {q}
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 flex-shrink-0 rotate-0 transition-transform group-open:rotate-180 text-text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="border-t border-border px-5 py-4 text-sm leading-relaxed text-text-muted">{a}</div>
          </details>
        ))}
      </div>

      <div class="mt-10 text-center">
        <p class="mb-5 text-sm leading-relaxed text-text-muted">
          It's probably time to stop scrolling and start shopping. Treat yourself (and your fishing gear) to one of our awesome bait boards.
        </p>
        <a href="/collections/bait-boards" class="button-accent">Shop Bait Boards</a>
      </div>
    </div>
  </section>

</BaseLayout>
