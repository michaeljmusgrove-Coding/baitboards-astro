---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "About Bait Boards Direct | Premium Fiberglass Bait Boards";
const description = "Bait Boards Direct is South East Melbourne's home of premium fiberglass bait boards. We source directly from manufacturers to bring serious anglers the best quality at unbeatable prices.";
---

<BaseLayout title={title} description={description}>
  <section class="bg-bg-alt py-16 sm:py-20">
    <div class="container max-w-3xl">
      <h1 class="font-heading mb-6 text-3xl font-bold text-primary sm:text-4xl">About Us</h1>
      <div class="prose prose-lg max-w-none text-text-muted space-y-5">
        <p>
          Welcome to Bait Boards Direct — your premier destination for fiberglass bait boards in Australia. Situated in the vibrant heart of South East Melbourne, we've become the go-to destination for anglers seeking premium products that elevate their fishing experience.
        </p>
        <p>
          Our mission is simple: provide the best quality fiberglass bait boards on the planet at jaw-dropping prices. We achieve this by buying directly from manufacturers, cutting out all the middlemen and passing every dollar of saving straight to you.
        </p>
        <h2 class="font-heading text-2xl font-bold text-primary mt-8">Why Choose Bait Boards Direct?</h2>
        <ul class="space-y-3">
          <li><strong>Unrivalled Quality:</strong> Every board is crafted from full composite fiberglass — UV-resistant, marine-grade, and built to handle the harshest conditions offshore.</li>
          <li><strong>Direct Pricing:</strong> No retail markup. We import direct, so you pay wholesale prices on premium product.</li>
          <li><strong>Wide Range:</strong> From compact bait prep boards to full leaning post setups with integrated sinks, rod holders, and knife trays — we have the right setup for your vessel.</li>
          <li><strong>Backed by Anglers:</strong> Our team are passionate fishermen. We only stock gear we'd use ourselves.</li>
        </ul>
        <p class="mt-6">
          Whether you're rigging up for a weekend snapper session or a serious offshore blue water run, a Bait Boards Direct setup will make your time on the water smoother, cleaner, and more productive.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
