---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Shipping Policy | Bait Boards Direct";
const description = "Bait Boards Direct shipping policy. Free shipping on all orders across Australia. Most orders dispatched within 1–3 business days.";
---

<BaseLayout title={title} description={description}>
  <section class="bg-bg-alt py-16 sm:py-20">
    <div class="container max-w-3xl">
      <h1 class="font-heading mb-8 text-3xl font-bold text-primary sm:text-4xl">Shipping Policy</h1>
      <div class="prose max-w-none policy-content text-text-muted space-y-6 text-sm leading-relaxed">

        <div class="rounded-xl bg-accent/20 border border-accent/30 px-5 py-4">
          <p class="font-semibold text-primary">🚚 Free shipping on all orders across Australia.</p>
        </div>

        <h2 class="font-heading text-xl font-bold text-primary">Processing Time</h2>
        <p>Most orders are processed and dispatched within 1–3 business days. You'll receive a confirmation email with tracking information once your order has shipped.</p>

        <h2 class="font-heading text-xl font-bold text-primary">Delivery Timeframes</h2>
        <table class="w-full border-collapse text-sm">
          <thead>
            <tr class="border-b border-border">
              <th class="py-2 text-left font-semibold text-primary">Region</th>
              <th class="py-2 text-left font-semibold text-primary">Estimated Delivery</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-border">
              <td class="py-3">Melbourne Metro</td>
              <td class="py-3">2–4 business days</td>
            </tr>
            <tr class="border-b border-border">
              <td class="py-3">Sydney, Brisbane, Adelaide, Perth</td>
              <td class="py-3">4–7 business days</td>
            </tr>
            <tr class="border-b border-border">
              <td class="py-3">Regional Victoria & NSW</td>
              <td class="py-3">5–8 business days</td>
            </tr>
            <tr>
              <td class="py-3">Remote Areas & NT, WA outback</td>
              <td class="py-3">7–14 business days</td>
            </tr>
          </tbody>
        </table>

        <h2 class="font-heading text-xl font-bold text-primary">Freight Method</h2>
        <p>Large bait boards and fillet tables are shipped via road freight on a pallet or oversize parcel service. Smaller accessories such as rod holders and mounting legs ship via standard parcel post. A signature may be required on delivery for larger items.</p>

        <h2 class="font-heading text-xl font-bold text-primary">Order Tracking</h2>
        <p>Once your order is dispatched you'll receive an email with a tracking number. If you haven't received your tracking details within 4 business days of ordering, please <a href="/contact" class="text-primary underline underline-offset-2 hover:text-accent transition-colors">contact us</a>.</p>

        <h2 class="font-heading text-xl font-bold text-primary">Damaged in Transit</h2>
        <p>If your order arrives damaged, please photograph the damage before opening and contact us within 7 days of delivery. We'll arrange a replacement or refund promptly.</p>

        <p class="text-xs text-text-muted/70 pt-4 border-t border-border">Last updated: May 2026</p>
      </div>
    </div>
  </section>
</BaseLayout>
