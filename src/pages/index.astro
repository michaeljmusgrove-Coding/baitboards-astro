---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../config/site';

const title = `${site.name} — ${site.tagline}`;
const description = site.description;
---

<BaseLayout title={title} description={description}>

  <!-- Hero -->
  <section class="bg-dark-hero text-white">
    <div class="container py-20 sm:py-28">
      <div class="max-w-2xl">
        <p class="font-heading mb-3 text-sm font-semibold uppercase tracking-widest text-accent">
          Australian Made · Composite Fiberglass
        </p>
        <h1 class="font-heading mb-6 text-4xl font-extrabold leading-tight sm:text-5xl lg:text-6xl">
          Premium Bait Boards<br class="hidden sm:block" /> for Serious Anglers
        </h1>
        <p class="mb-8 max-w-xl text-base leading-relaxed text-white/70 sm:text-lg">
          SeaKing bait boards and fillet tables — handcrafted from composite fiberglass with marine-grade
          stainless fittings. Built for offshore. Free delivery across Australia.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/collections/bait-boards" class="button-accent">Shop Bait Boards</a>
          <a href="/about" class="button">About Us</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust bar -->
  <section class="border-y border-border bg-white">
    <div class="container py-5">
      <ul class="flex flex-wrap justify-center gap-6 text-sm font-semibold text-primary sm:gap-10">
        <li class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
          Free Shipping Nationwide
        </li>
        <li class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
          Composite Fiberglass Build
        </li>
        <li class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
          Marine-Grade Stainless 316
        </li>
        <li class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
          Afterpay Available
        </li>
      </ul>
    </div>
  </section>

  <!-- Shop collections -->
  <section class="bg-bg-alt py-16 sm:py-20">
    <div class="container">
      <h2 class="font-heading mb-10 text-center text-2xl font-bold text-primary sm:text-3xl">
        Shop by Category
      </h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <a href="/collections/bait-boards" class="group rounded-2xl border border-border bg-white p-8 shadow-sm transition hover:shadow-md">
          <p class="font-heading mb-2 text-lg font-bold text-primary group-hover:text-accent transition-colors">Bait Boards</p>
          <p class="text-sm leading-relaxed text-text-muted">Full composite fiberglass bait boards with integrated sink, drain, and rod holders.</p>
          <p class="mt-4 text-sm font-semibold text-primary group-hover:text-accent transition-colors">Browse range →</p>
        </a>
        <a href="/collections/bait-boards-with-legs" class="group rounded-2xl border border-border bg-white p-8 shadow-sm transition hover:shadow-md">
          <p class="font-heading mb-2 text-lg font-bold text-primary group-hover:text-accent transition-colors">Boards with Legs</p>
          <p class="text-sm leading-relaxed text-text-muted">Bait boards with stainless 316 adjustable legs for gunnel or leaning post mounting.</p>
          <p class="mt-4 text-sm font-semibold text-primary group-hover:text-accent transition-colors">Browse range →</p>
        </a>
        <a href="/collections/on-sale" class="group rounded-2xl border border-border bg-white p-8 shadow-sm transition hover:shadow-md">
          <p class="font-heading mb-2 text-lg font-bold text-sale group-hover:underline transition-colors">On Sale</p>
          <p class="text-sm leading-relaxed text-text-muted">Discounted boards and accessories — limited stock while they last.</p>
          <p class="mt-4 text-sm font-semibold text-sale">View sale items →</p>
        </a>
      </div>
    </div>
  </section>

  <!-- Why SeaKing -->
  <section class="py-16 sm:py-20">
    <div class="container max-w-4xl">
      <h2 class="font-heading mb-10 text-center text-2xl font-bold text-primary sm:text-3xl">
        Built for Offshore. Designed to Last.
      </h2>
      <div class="grid gap-8 sm:grid-cols-2">
        <div>
          <h3 class="font-heading mb-2 text-base font-bold text-primary">Full Composite Fiberglass</h3>
          <p class="text-sm leading-relaxed text-text-muted">
            Every SeaKing board is handcrafted from full composite fiberglass — not marine ply, not aluminium.
            Impervious to rot, corrosion, and UV degradation.
          </p>
        </div>
        <div>
          <h3 class="font-heading mb-2 text-base font-bold text-primary">PE Plastic Cutting Surface</h3>
          <p class="text-sm leading-relaxed text-text-muted">
            UV-resistant polyethylene cutting board surface. Food-safe, easy to clean, won't stain or absorb odours.
          </p>
        </div>
        <div>
          <h3 class="font-heading mb-2 text-base font-bold text-primary">Integrated Sink & Drain</h3>
          <p class="text-sm leading-relaxed text-text-muted">
            Built-in stainless sink and drain on all full-size boards. Connect a standard hose fitting and you're done.
          </p>
        </div>
        <div>
          <h3 class="font-heading mb-2 text-base font-bold text-primary">Direct from Manufacturer</h3>
          <p class="text-sm leading-relaxed text-text-muted">
            We manufacture and sell direct, with no markup from distributors. Premium quality at a fair price.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ teaser -->
  <section class="bg-bg-alt py-16 sm:py-20">
    <div class="container max-w-2xl text-center">
      <h2 class="font-heading mb-4 text-2xl font-bold text-primary">Have questions?</h2>
      <p class="mb-6 text-sm leading-relaxed text-text-muted">
        Check our FAQ for answers on sizing, installation, shipping, and more.
      </p>
      <a href="/faqs" class="button">View FAQs</a>
    </div>
  </section>

</BaseLayout>
