---
import BaseLayout from "./BaseLayout.astro";
---

<BaseLayout
  title="Page Not Found | Bait Boards Direct"
  description="The page you were looking for doesn't exist. Browse our range of bait boards and fishing accessories."
  noindex={true}
>
  <section class="bg-bg-alt flex flex-1 items-center py-24">
    <div class="container text-center">
      <p class="font-heading text-8xl font-extrabold text-accent-text">404</p>
      <h1 class="font-heading mt-4 text-2xl font-bold text-primary sm:text-3xl">Page not found</h1>
      <p class="mt-4 text-text-muted">
        The page you were looking for doesn't exist or has been moved.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/" class="button">Go home</a>
        <a href="/collections/bait-boards" class="button-accent">Browse bait boards</a>
      </div>
    </div>
  </section>
</BaseLayout>
